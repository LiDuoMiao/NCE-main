        }
      ]
    },
    {
      "title": "情态动词 could 的用法",
      "definition": "could 是 can 的过去式，表示过去的能力或可能性",
      "structure": "主语 + could/could not + 动词原形",
      "usage": "表示过去能够或不能做某事，用于否定句时表示无法忍受",
      "examples": [
        {
          "en": "I could not hear the actors.",
          "zh": "我听不到演员的声音。"
        },
        {
          "en": "In the end, I could not bear it.",
          "zh": "最后，我无法忍受了。"
        }
      ]
    },
    {
      "title": "直接引语 (Direct Speech)",
      "definition": "直接引用别人的话，用引号括起来",
      "structure": "主语 + said/said angrily + \"引语\"",
      "usage": "用于直接转述某人说的话，保持原话的语气和用词",
      "examples": [
        {
          "en": "I can't hear a word!' I said angrily.",
          "zh": "我一个字也听不见！我生气地说。"
