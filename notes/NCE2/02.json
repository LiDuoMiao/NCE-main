  "grammar": [
    {
      "title": "现在进行时 (Present Continuous Tense)",
      "definition": "表示说话时正在进行的动作或当前阶段正在发生的动作",
      "structure": "主语 + am/is/are + 动词-ing",
      "usage": "用于描述正在进行的动作，常与now, just, right now等时间状语连用",
      "examples": [
        {
          "en": "I'm having breakfast.",
          "zh": "我正在吃早餐。"
        },
        {
          "en": "It's raining again.",
          "zh": "天又下雨了。"
        },
        {
          "en": "I'm coming to see you.",
          "zh": "我正要来看你。"
        }
      ]
    },
    {
      "title": "一般现在时 (Present Simple Tense)",
      "definition": "表示习惯性动作、客观事实或普遍真理",
      "structure": "主语 + 动词原形（第三人称单数要加-s/-es）",
      "usage": "用于描述经常性或习惯性的动作，常与always, often, sometimes等频度副词连用",
      "examples": [
        {
          "en": "I never get up early on Sundays.",
          "zh": "我星期天从不在早起。"
        },
        {
          "en": "Do you always get up so late?",
          "zh": "你总是这么晚起床吗？"
        }
      ]
    },
    {
      "title": "特殊疑问句 (Special Question)",
      "definition": "用疑问词（what, where, when等）开头的问句，需要详细回答",
      "structure": "疑问词 + 一般疑问句？",
      "usage": "用于询问具体信息，如正在做什么、原因、时间等",
      "examples": [
        {
          "en": "What are you doing?",
          "zh": "你正在做什么？"
        },
        {
          "en": "Why was the writer's aunt surprised?",
          "zh": "为什么作家的姑妈感到惊讶？"
        }
      ]
    }
  ],
