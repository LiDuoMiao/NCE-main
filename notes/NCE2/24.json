  "grammar": [
    {
      "title": "过去完成时 (Past Perfect Tense)",
      "definition": "表示在过去某一时间之前已经完成的动作，强调'过去的过去'",
      "structure": "主语 + had + 过去分词",
      "usage": "用于描述两个过去的动作，先发生的动作用过去完成时，后发生的动作用一般过去时",
      "examples": [
        {
          "en": "I had just lost £50 when I went to the manager.",
          "zh": "当我去找经理时，我刚刚丢了50英镑。"
        },
        {
          "en": "She had finished her work before she left.",
          "zh": "她在离开前已经完成了工作。"
        }
      ]
    },
    {
      "title": "some在肯定句中的用法",
      "definition": "some通常用于肯定句中，表示'一些，某些'",
      "structure": "some + 可数名词复数/不可数名词",
      "usage": "some用于肯定句中可以指代不确定的数量，也可用于邀请或期望肯定回答的疑问句中",
      "examples": [
        {
          "en": "There is still some honesty in this world.",
          "zh": "这个世界上仍然有一些诚实。"
        },
        {
          "en": "Would you like some tea?",
          "zh": "你想要一些茶吗？"
        }
      ]
    }
  ],
