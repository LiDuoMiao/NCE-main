  "grammar": [
    {
      "title": "Do引导的一般疑问句 (Do you want/like...?)",
      "definition": "用Do开头询问对方是否想要或喜欢某事，需要用yes或no回答",
      "structure": "Do + 主语 + 动词原形 + ...?",
      "usage": "用于询问对方的意愿或喜好",
      "examples": [
        {
          "en": "Do you want a cup of tea?",
          "zh": "你想要一杯茶吗？"
        },
        {
          "en": "Do you like coffee?",
          "zh": "你喜欢咖啡吗？"
        },
        {
          "en": "Do you want any sugar?",
          "zh": "你想要些糖吗？"
        }
      ]
    },
    {
      "title": "Some和Any的用法",
      "definition": "some用于肯定句，any用于疑问句和否定句",
      "structure": "Do you want any + 名词? / I don't want any + 名词",
      "usage": "some在疑问句中表示希望得到肯定回答时也可用",
      "examples": [
        {
          "en": "Do you want any sugar?",
          "zh": "你想要些糖吗？"
        },
        {
          "en": "I don't like any milk in my coffee.",
          "zh": "我不喜欢在咖啡里加牛奶。"
        }
      ]
    },
    {
      "title": "want和like的区别",
      "definition": "want表示想要（当前需求），like表示喜欢（一般喜好）",
      "structure": "Do you want...? / Do you like...?",
      "usage": "want用于询问具体需求，like用于询问偏好",
      "examples": [
        {
          "en": "Do you want a biscuit now?",
          "zh": "你现在想要块饼干吗？（当前需求）"
        },
        {
          "en": "Do you like biscuits?",
          "zh": "你喜欢饼干吗？（一般喜好）"
        }
      ]
    }
  ],
