          "zh": "非常感谢！"
        }
      ]
    },
    {
      "phrase": "The red one",
      "usage": "用颜色+one来指代特定物品，避免重复",
      "examples": [
        {
          "en": "I want the red one.",
          "zh": "我想要红色的那个。"
        }
      ]
    }
  ],
  "grammar": [
    {
      "title": "Which引导的特殊疑问句",
      "definition": "用which提问，要求从已知选项中选择答案",
      "structure": "Which + 名词 + ...?",
      "usage": "用于询问特定范围内的人或物",
      "examples": [
        {
          "en": "Which book do you want?",
          "zh": "你想要哪本书？"
        },
        {
          "en": "Which one is yours?",
          "zh": "哪一个是你的？"
        }
      ]
    },
    {
      "title": "指示代词 this/that 与 one 的连用",
      "definition": "this one/that one 代替前面提到的名词，避免重复",
      "structure": "This/That + one",
      "usage": "在对话中指代已提及的物品，this指近处，that指远处",
      "examples": [
        {
          "en": "This one? No, that one.",
          "zh": "这个？不，是那个。"
        },
        {
          "en": "I like this one better.",
          "zh": "我更喜欢这个。"
        }
      ]
    },
    {
      "title": "颜色+one结构",
      "definition": "用'the + 颜色 + one'来特指某个物品",
      "structure": "The + 颜色 + one",
      "usage": "当有多个相同物品但颜色不同时，用此结构指明具体哪一个",
      "examples": [
        {
          "en": "The red one is mine.",
          "zh": "红色那个是我的。"
        },
        {
          "en": "Give me the blue one please.",
          "zh": "请给我蓝色的那个。"
        }
      ]
    }
  ],
