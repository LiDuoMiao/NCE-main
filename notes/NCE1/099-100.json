  "grammar": [
    {
      "title": "现在完成时 (Present Perfect Tense)",
      "definition": "由have/has + 过去分词构成，表示过去发生的动作对现在造成的影响，或表示动作持续到现在",
      "structure": "主语 + have/has + 过去分词 + (时间状语/地点)",
      "usage": "用于描述过去发生但与现在有关联的事情。在本课中，Have you hurt yourself? 询问的是过去发生的动作对现在的 影响",
      "examples": [
        {
          "en": "I have slipped and fallen downstairs.",
          "zh": "我从楼梯上滑倒摔下来了。"
        },
        {
          "en": "Have you hurt yourself?",
          "zh": "你伤到自己了吗？"
        },
        {
          "en": "Yes, I have. I think that I've hurt my back.",
          "zh": "是的，我伤到了。我想我伤到背了。"
        }
      ]
    },
    {
      "title": "had better 的用法",
      "definition": "had better表示建议或劝告，意为\"最好\"，含有轻微的警告或催促意味",
      "structure": "主语 + had better + 动词原形",
      "usage": "用于在特定情况下建议某人采取行动，语气比should稍强，比must弱",
      "examples": [
        {
          "en": "I think that the doctor had better see you.",
          "zh": "我认为你最好让医生看看。"
        },
        {
          "en": "You had better see a doctor.",
          "zh": "你最好去看医生。"
        }
      ]
    },
    {
      "title": "宾语从句 (that引导)",
      "definition": "由that引导的宾语从句，用于表达思想、观点或确信的内容",
      "structure": "主语 + think/believe/sure + that + 从句",
      "usage": "that可省略，用于补充说明主句动词的内容",
      "examples": [
        {
          "en": "I think that I've hurt my back.",
          "zh": "我想我伤到背了。"
        },
        {
          "en": "I'm sure that you need an X-ray.",
          "zh": "我确信你需要做X光检查。"
        }
      ]
    }
  ],
