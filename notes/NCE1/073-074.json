  "grammar": [
    {
      "title": "一般过去时 (Past Simple Tense)",
      "definition": "表示过去发生的动作或存在的状态，常与表示过去的时间状语连用，如last week, yesterday等。",
      "structure": "主语 + 动词过去式 + 其他\n主语 + did not (didn't) + 动词原形 + 其他",
      "usage": "用于叙述过去发生的事情，描述一系列按时间顺序发生的动作",
      "examples": [
        {
          "en": "Last week Mrs. Mills went to London.",
          "zh": "上周 Mills 夫人去了伦敦。"
        },
        {
          "en": "She lost her way.",
          "zh": "她迷路了。"
        },
        {
          "en": "He did not understand English.",
          "zh": "他不懂英语。"
        },
        {
          "en": "He took out a phrasebook.",
          "zh": "他拿出一本短语手册。"
        }
      ]
    },
    {
      "title": "一般过去时的否定句和疑问句",
      "definition": "否定句在动词前加did not (didn't)，动词恢复原形。疑问句将did提到句首。",
      "structure": "否定句: 主语 + did not + 动词原形 + 其他\n一般疑问句: Did + 主语 + 动词原形 + 其他？",
      "usage": "用于对过去发生的动作进行否定或提问",
      "examples": [
        {
          "en": "He did not understand English.",
          "zh": "他不懂英语。"
        },
        {
          "en": "Did she lose her way?",
          "zh": "她迷路了吗？"
        },
        {
          "en": "Did he speak German?",
          "zh": "他说德语吗？"
        }
      ]
    },
    {
      "title": "一般过去时与一般现在时的对比",
      "definition": "一般现在时描述习惯性或经常发生的动作；一般过去时描述过去发生的具体事件。",
      "structure": "现在时: 主语 + 动词原形/三单形式\n过去时: 主语 + 动词过去式",
      "usage": "在叙述故事时，背景描述用现在时，具体事件用过去时",
      "examples": [
        {
          "en": "She does not know London very well.",
          "zh": "她对伦敦不太熟悉。（现在时，描述一般状态）"
        },
        {
          "en": "She lost her way.",
          "zh": "她迷路了。（过去时，描述过去事件）"
        }
      ]
    }
  ],
