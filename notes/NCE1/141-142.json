  "grammar": [
    {
      "title": "过去进行时 (Past Continuous Tense)",
      "definition": "表示在过去某一时刻或时间段正在进行的动作",
      "structure": "主语 + was/were + 动词-ing",
      "usage": "用于描述过去正在发生的事情，常与when/while连用",
      "examples": [
        {
          "en": "Sally was sitting near the window when a lady got on.",
          "zh": "当一位女士上车时，莎莉正坐在窗边。"
        },
        {
          "en": "The lady was dressed in a blue coat.",
          "zh": "那位女士穿着一件蓝色外套。"
        }
      ]
    },
    {
      "title": "特殊疑问句 - Why 引导的原因疑问句",
      "definition": "用Why提问原因或理由",
      "structure": "Why + be动词/助动词 + 主语 + ...?",
      "usage": "询问某人做某事的原因",
      "examples": [
        {
          "en": "Why are you doing that?",
          "zh": "你为什么要那样做？"
        },
        {
          "en": "Why was the mother embarrassed?",
          "zh": "为什么妈妈感到尴尬？"
        }
      ]
    },
    {
      "title": "but连接的转折句",
      "definition": "用but连接两个意思相反的句子",
      "structure": "主句 + , but + 句子",
      "usage": "表示前后意思的转折对比",
      "examples": [
        {
          "en": "Sally was amused, but I was very embarrassed!",
          "zh": "莎莉觉得好笑，但我却非常尴尬！"
        }
      ]
    }
  ],
