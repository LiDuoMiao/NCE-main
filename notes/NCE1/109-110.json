  "grammar": [
    {
      "title": "Would you like...? 与 Do you want...? 的区别",
      "definition": "would you like用于更正式、礼貌的场合，提出邀请或询问意愿；do you want较为直接，表示询问需求",
      "structure": "Would you like + 名词/动词不定式?\nDo you want + 名词/动词不定式?",
      "usage": "would you like常用于正式场合或礼貌邀请，do you want用于一般询问",
      "examples": [
        {
          "en": "Would you like some coffee?",
          "zh": "你想要咖啡吗？（礼貌邀请）"
        },
        {
          "en": "Do you want any coffee?",
          "zh": "你想要咖啡吗？（一般询问）"
        },
        {
          "en": "Would you like to have dinner with me?",
          "zh": "你愿意和我一起吃晚饭吗？（正式邀请）"
        }
      ]
    },
    {
      "title": "May I...? 询问许可",
      "definition": "may是较为正式的请求许可的助动词，意为'可以'，回答可用Of course/Sure/Certainly等",
      "structure": "May I + 动词原形?",
      "usage": "用于正式场合请求许可，比Can I...更礼貌",
      "examples": [
        {
          "en": "May I have one?",
          "zh": "我可以要一根吗？"
        },
        {
          "en": "May I come in?",
          "zh": "我可以进来吗？"
        },
        {
          "en": "May I use your phone?",
          "zh": "我可以用你的电话吗？"
        }
      ]
    },
    {
      "title": "数量表达：a little, a few, less, more",
      "definition": "a little修饰不可数名词表示'一点'；a few修饰可数名词表示'一些'；less是little的比较级；more是many/much的比较级",
      "structure": "a little + 不可数名词\na few + 可数名词复数\nmore + 名词\nless + 不可数名词",
      "usage": "用于表达不同程度的数量，less than表示'少于'，more表示'更多'",
      "examples": [
        {
          "en": "Just a little milk, please.",
          "zh": "请给我一点牛奶。"
        },
        {
          "en": "I think there are a few in that box.",
          "zh": "我想盒子里有一些。"
        },
        {
          "en": "Less than that.",
          "zh": "比那少一点。"
        },
        {
          "en": "Would you like some more?",
          "zh": "你想要再来一些吗？"
        }
      ]
    }
  ],
