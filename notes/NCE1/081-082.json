  "grammar": [
    {
      "title": "一般过去时 (Past Simple Tense)",
      "definition": "表示过去发生的动作或存在的状态",
      "structure": "主语 + 动词过去式 + 其他",
      "usage": "描述过去发生的事情，句中常有时间状语如yesterday, last week, today等",
      "examples": [
        {
          "en": "We had roast beef and potatoes.",
          "zh": "我们吃了烤牛肉和土豆。"
        },
        {
          "en": "Sam and I had lunch together today.",
          "zh": "今天我和萨姆一起吃了午饭。"
        }
      ]
    },
    {
      "title": "一般过去时的否定句和疑问句",
      "definition": "在一般过去时中，否定句用did not (didn't)，疑问句用Did引导",
      "structure": "Did + 主语 + 动词原形 + 其他？",
      "usage": "询问过去发生的事情",
      "examples": [
        {
          "en": "What did you have?",
          "zh": "你们吃了什么？"
        },
        {
          "en": "Did you enjoy your meal?",
          "zh": "你喜欢那顿饭吗？"
        }
      ]
    },
    {
      "title": "be going to 表示将来计划",
      "definition": "表示已经计划好或决定好的将来动作",
      "structure": "主语 + be going to + 动词原形",
      "usage": "表示根据计划或决定即将发生的事情",
      "examples": [
        {
          "en": "You're going to have roast beef and potatoes again tonight!",
          "zh": "今晚你们又要吃烤牛肉和土豆了！"
        }
      ]
    }
  ],
