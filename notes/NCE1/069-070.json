  "grammar": [
    {
      "title": "There be句型的过去式",
      "definition": "There be句型用于表示某地存在某人或某物，过去式分别用There was（单数）和There were（复数）",
      "structure": "There was/were + 名词 + 地点/时间",
      "usage": "描述过去某处存在的人或物，注意there was后接单数名词，there were后接复数名词",
      "examples": [
        {
          "en": "There was a very big race in 1995.",
          "zh": "1995年有一场非常大的比赛。"
        },
        {
          "en": "There were twenty cars in the race.",
          "zh": "比赛中有20辆车。"
        },
        {
          "en": "There were hundreds of people there.",
          "zh": "那里有数百人。"
        }
      ]
    },
    {
      "title": "一般过去时（Simple Past Tense）",
      "definition": "表示过去某一时间发生的动作或存在的状态，动词用过去式",
      "structure": "主语 + 动词过去式 + 其他",
      "usage": "描述过去发生的事情，常见的过去式变化包括：规则动词加-ed，不规则动词需单独记忆",
      "examples": [
        {
          "en": "The winner was Billy Stewart.",
          "zh": "获胜者是Billy Stewart。"
        },
        {
          "en": "My wife and I were at the race.",
          "zh": "我和妻子在比赛现场。"
        },
        {
          "en": "She said to me, 'Don't drive so quickly!'",
          "zh": "她对我说：'别开这么快！'"
        }
      ]
    },
    {
      "title": "方位表达：on the left/right",
      "definition": "表示在某物的左边或右边",
      "structure": "on the left / on the right",
      "usage": "用于描述位置，常与standing、sitting等动词连用",
      "examples": [
        {
          "en": "We are standing on the left.",
          "zh": "我们站在左边。"
        },
        {
          "en": "The shop is on the right side of the street.",
          "zh": "那家商店在街道右边。"
        }
      ]
    }
  ],
