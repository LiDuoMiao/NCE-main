  "grammar": [
    {
      "title": "现在完成时（Present Perfect）与since/for连用",
      "definition": "现在完成时表示从过去开始一直持续到现在的动作或状态，与since（自从）和for（持续）连用。",
      "structure": "主语 + have/has + 过去分词 + for + 时间段 / since + 时间点",
      "usage": "用于询问或描述持续了多长时间的动作或状态，since后接具体时间点，for后接时间段。",
      "examples": [
        {
          "en": "I've lived here for twenty years.",
          "zh": "我在这里住了二十年。"
        },
        {
          "en": "I've been here since 1976.",
          "zh": "我从1976年就在这里了。"
        },
        {
          "en": "I've just retired.",
          "zh": "我刚退休。"
        }
      ]
    },
    {
      "title": "must表示必要性",
      "definition": "must是情态动词，表示必须、一定，用于表达主观上的必要性。",
      "structure": "主语 + must + 动词原形",
      "usage": "must see it first表示'必须先看一看'，强调必要性。",
      "examples": [
        {
          "en": "My wife must see it first.",
          "zh": "我妻子必须先看一看。"
        },
        {
          "en": "I must go now.",
          "zh": "我必须走了。"
        }
      ]
    },
    {
      "title": "cost的用法",
      "definition": "cost表示'花费'，主语通常是事物，而不是人。",
      "structure": "某物 + cost + 金钱",
      "usage": "询问价格时用How much does/did + 主语 + cost?",
      "examples": [
        {
          "en": "How much does this house cost?",
          "zh": "这所房子多少钱？"
        },
        {
          "en": "This book costs 20 pounds.",
          "zh": "这本书20英镑。"
        }
      ]
    }
  ],
