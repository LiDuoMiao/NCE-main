  "grammar": [
    {
      "title": "一般疑问句：Is that...for me?",
      "definition": "使用Is引导的一般疑问句，用来询问某物是否是为某人准备的或给某人的",
      "structure": "Is that + 名词 + for + 人称代词/名词?",
      "usage": "这种句型用于确认某物的归属或用途，回答通常用Yes或No",
      "examples": [
        {
          "en": "Is that tin of tobacco for me?",
          "zh": "那罐烟草是给我的吗？"
        },
        {
          "en": "Is this book for you?",
          "zh": "这本书是你的吗？"
        },
        {
          "en": "Is that coffee for Penny?",
          "zh": "那杯咖啡是给彭妮的吗？"
        }
      ]
    },
    {
      "title": "数量词组（量词）与名词的搭配",
      "definition": "英语中常用量词来修饰不可数名词，表示具体的数量",
      "structure": "a/an/数词 + 量词 + of + 不可数名词",
      "usage": "不同的物品使用不同的量词，如a piece of cheese（一块奶酪）、a loaf of bread（一条面包）、a bar of soap（一块肥皂）等",
      "examples": [
        {
          "en": "a piece of cheese",
          "zh": "一块奶酪"
        },
        {
          "en": "a loaf of bread",
          "zh": "一条面包"
        },
        {
          "en": "a bar of soap",
          "zh": "一块肥皂"
        },
        {
          "en": "a bottle of milk",
          "zh": "一瓶牛奶"
        }
      ]
    },
    {
      "title": "否定陈述句：It's certainly not for me",
      "definition": "使用certainly加强否定语气，表示强烈的否定含义",
      "structure": "It's certainly not + for + ...",
      "usage": "certainly放在not之前用来加强否定语气，表示非常确定某物不是为某人准备的",
      "examples": [
        {
          "en": "It's certainly not for me!",
          "zh": "肯定不是给我的！"
        },
        {
          "en": "It's certainly not for her.",
          "zh": "肯定不是给她的。"
        },
        {
          "en": "This is certainly not a problem.",
          "zh": "这肯定不是问题。"
        }
      ]
    }
  ],
