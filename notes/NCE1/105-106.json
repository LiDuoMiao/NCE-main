  "grammar": [
    {
      "title": "Want + 宾语 + to + 动词原形",
      "definition": "表示说话者希望或要求另一个人做某事",
      "structure": "主语 + want + 宾语 + to + 动词原形",
      "usage": "用于表达想让某人做某事的意愿，want后面需要跟宾语（人），再加to引导的不定式短语",
      "examples": [
        {
          "en": "I want her to come to my office.",
          "zh": "我想让她来我的办公室。"
        },
        {
          "en": "I want you to type it again.",
          "zh": "我想让你再打一遍。"
        },
        {
          "en": "Do you want her to come at once?",
          "zh": "你想让她马上来吗？"
        }
      ]
    },
    {
      "title": "Tell + 宾语 + to + 动词原形",
      "definition": "表示命令或指示某人做某事",
      "structure": "主语 + tell + 宾语 + to + 动词原形",
      "usage": "用于传达命令或指示，要求宾语（通常是人）执行某个动作",
      "examples": [
        {
          "en": "Tell her to come at once.",
          "zh": "告诉她立刻来。"
        },
        {
          "en": "Tell him to wait outside.",
          "zh": "让他在外面等。"
        },
        {
          "en": "Tell them to be quiet.",
          "zh": "让他们安静。"
        }
      ]
    },
    {
      "title": "Have/Has + 过去分词（现在完成时）",
      "definition": "表示过去发生的动作对现在造成的影响或结果",
      "structure": "主语 + have/has + 过去分词",
      "usage": "常与just连用，表示刚刚完成的动作。在本课中用于指出对方的错误",
      "examples": [
        {
          "en": "You've typed it with only one 'L'.",
          "zh": "你只打了一个'L'。"
        },
        {
          "en": "She's already finished her work.",
          "zh": "她已经完成了工作。"
        },
        {
          "en": "I've made a mistake.",
          "zh": "我犯了一个错误。"
        }
      ]
    }
  ],
