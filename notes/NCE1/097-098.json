  "grammar": [
    {
      "title": "一般疑问句（Yes/No Questions）",
      "definition": "可以用 yes 或 no 回答的疑问句，通过将 be 动词、情态动词或助动词移至句首构成",
      "structure": "Be动词/情态动词 + 主语 + ...?",
      "usage": "用于询问某物是否属于某人、某物的特征等",
      "examples": [
        {
          "en": "Is this case yours?",
          "zh": "这个箱子是你的吗？"
        },
        {
          "en": "Is this seat taken?",
          "zh": "这个座位有人吗？"
        },
        {
          "en": "Are you a student?",
          "zh": "你是学生吗？"
        }
      ]
    },
    {
      "title": "物主代词（Possessive Pronouns）",
      "definition": "表示所有关系的代词，分为形容词性物主代词和名词性物主代词",
      "structure": "形容词性物主代词 + 名词 / 名词性物主代词（单独使用）",
      "usage": "表示某物属于某人所有",
      "examples": [
        {
          "en": "No, that's not mine.",
          "zh": "不，那不是我的。"
        },
        {
          "en": "Is this your case?",
          "zh": "这是你的箱子吗？"
        },
        {
          "en": "This is my suitcase.",
          "zh": "这是我的手提箱。"
        }
      ]
    },
    {
      "title": "have got 的用法",
      "definition": "have got 在英式英语中相当于 have，表示拥有或具有某种特征",
      "structure": "主语 + have/has got + 名词/形容词",
      "usage": "用于描述某物具有某种特征或某人拥有某物",
      "examples": [
        {
          "en": "It's got a zip.",
          "zh": "它有拉链。"
        },
        {
          "en": "This one's got a label.",
          "zh": "这个有标签。"
        },
        {
          "en": "He has got a new car.",
          "zh": "他有一辆新车。"
        }
      ]
    }
  ],
