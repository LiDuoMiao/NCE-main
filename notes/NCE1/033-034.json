  "grammar": [
    {
      "title": "There be 句型",
      "definition": "表示某地存在某物或某人",
      "structure": "There is/are + 名词 + 地点",
      "usage": "表示客观存在的'有'，与 have/has 不同",
      "examples": [
        {
          "en": "There are some clouds in the sky.",
          "zh": "天空中有一些云。"
        },
        {
          "en": "There are some boats on the river.",
          "zh": "河上有一些船。"
        }
      ]
    },
    {
      "title": "现在进行时",
      "definition": "表示正在发生的动作",
      "structure": "主语 + be + 动词-ing",
      "usage": "描述说话时正在进行的动作",
      "examples": [
        {
          "en": "They are walking over the bridge.",
          "zh": "他们正在走过桥。"
        },
        {
          "en": "The ship is going under the bridge.",
          "zh": "轮船正从桥下驶过。"
        }
      ]
    },
    {
      "title": "方位介词 over 和 under",
      "definition": "over 表示在...上方（不接触），under 表示在...下方",
      "structure": "over/under + 名词",
      "usage": "描述物体之间的相对位置关系",
      "examples": [
        {
          "en": "The ship is going under the bridge.",
          "zh": "轮船正从桥下驶过。"
        },
        {
          "en": "The aeroplane is flying over the river.",
          "zh": "飞机正飞过河的上空。"
        }
      ]
    }
  ],
