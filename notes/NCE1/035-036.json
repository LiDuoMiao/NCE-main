  "grammar": [
    {
      "title": "现在进行时 (Present Continuous Tense)",
      "definition": "表示正在进行的动作或发生的事情",
      "structure": "主语 + is/am/are + 动词-ing形式",
      "usage": "用于描述说话时正在发生的动作，或在描述一系列同时发生的动作时使用",
      "examples": [
        {
          "en": "My wife and I are walking along the banks of the river.",
          "zh": "我和妻子正沿着河岸走。"
        },
        {
          "en": "He is swimming across the river.",
          "zh": "他正在游过河。"
        },
        {
          "en": "Some children are coming out of the building.",
          "zh": "一些孩子正从楼里出来。"
        }
      ]
    },
    {
      "title": "地点介词 (Prepositions of Place)",
      "definition": "用于表示事物位置关系的介词",
      "structure": "in（在...里面）/ on（在...上面）/ between（在...之间）/ beside（在...旁边）",
      "usage": "描述某人或某物所在的具体位置",
      "examples": [
        {
          "en": "Our village is in a valley.",
          "zh": "我们的村庄在山谷里。"
        },
        {
          "en": "It is between two hills.",
          "zh": "它在两座小山之间。"
        },
        {
          "en": "The park is on the right.",
          "zh": "公园在右边。"
        },
        {
          "en": "It is beside a park.",
          "zh": "它在一个公园旁边。"
        }
      ]
    },
    {
      "title": "Here is/are... 句型",
      "definition": "用于介绍或展示某物的句型",
      "structure": "Here is/are + 名词",
      "usage": "在对话或叙述中引出新的信息或展示某物",
      "examples": [
        {
          "en": "Here is another photograph of the village.",
          "zh": "这是我们村庄的又一张照片。"
        },
        {
          "en": "Here is another photograph.",
          "zh": "这是另一张照片。"
        }
      ]
    }
  ],
