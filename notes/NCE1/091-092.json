  "grammar": [
    {
      "title": "现在完成时 (Present Perfect Tense)",
      "definition": "现在完成时表示过去发生的动作或状态与现在有联系，强调结果或经验。构成形式为have/has + 过去分词。",
      "structure": "主语 + have/has + 过去分词 + (时间状语/地点状语)",
      "usage": "用于描述过去发生并已完成的动作，但强调该动作对现在的影响。常与already, yet, just, ever, never等副词连用。",
      "examples": [
        {
          "en": "He has sold his house.",
          "zh": "他已经卖了房子。"
        },
        {
          "en": "Has Ian sold his house yet?",
          "zh": "Ian已经把房子卖了吗？"
        },
        {
          "en": "He has always been a good neighbour.",
          "zh": "他一直是一个好邻居。"
        }
      ]
    },
    {
      "title": "现在完成时的一般疑问句",
      "definition": "现在完成时的疑问句用来询问过去的动作是否已经发生。has用于第三人称单数，have用于其他人称。",
      "structure": "Have/Has + 主语 + 过去分词 + (其他成分)?",
      "usage": "用Yes或No回答，否定回答用No, 主语 + hasn't/haven't。",
      "examples": [
        {
          "en": "Has he moved to his new house yet?",
          "zh": "他已经搬到新房子了吗？"
        },
        {
          "en": "Yes, he has.",
          "zh": "是的，他已经搬了。"
        },
        {
          "en": "No, not yet.",
          "zh": "不，还没有。"
        }
      ]
    },
    {
      "title": "一般过去时与现在完成时的区别",
      "definition": "一般过去时只表示过去的动作或状态，不强调与现在的关系；现在完成时强调过去动作对现在的影响。",
      "structure": "一般过去时：主语 + 过去式 + 时间状语\n现在完成时：主语 + have/has + 过去分词",
      "usage": "当明确指出具体过去时间时，用一般过去时；不强调具体时间而强调结果时，用现在完成时。",
      "examples": [
        {
          "en": "He sold it last week. (强调动作发生在上周)",
          "zh": "他上周卖了它。"
        },
        {
          "en": "He has sold his house. (强调已卖出的结果)",
          "zh": "他已经卖了房子。"
        }
      ]
    }
  ],
