  "grammar": [
    {
      "title": "含有be动词的一般疑问句",
      "definition": "用Yes或No回答的疑问句，询问某人的身份、国籍或物品归属",
      "structure": "Be动词(Am/Is/Are) + 主语 + ...?",
      "usage": "用于询问国籍、职业、身份或物品归属。肯定回答用Yes+主语+be动词；否定回答用No+主语+be动词+not",
      "examples": [
        {
          "en": "Are you Swedish?",
          "zh": "你是瑞典人吗？"
        },
        {
          "en": "Is this your passport?",
          "zh": "这是你的护照吗？"
        },
        {
          "en": "Are they Danish too?",
          "zh": "他们也是丹麦人吗？"
        }
      ]
    },
    {
      "title": "否定句（be动词的否定形式）",
      "definition": "在be动词后加not构成否定句",
      "structure": "主语 + be动词 + not + ...",
      "usage": "表示否定、拒绝或相反的情况。口语中常用缩略形式isn't, aren't, aren't",
      "examples": [
        {
          "en": "We are not Swedish. We are Danish.",
          "zh": "我们不是瑞典人，我们是丹麦人。"
        },
        {
          "en": "No, they aren't. They are Norwegian.",
          "zh": "不，他们不是。他们是挪威人。"
        },
        {
          "en": "These aren't our cases. Our cases are brown.",
          "zh": "这些不是我们的箱子。我们的箱子是棕色的。"
        }
      ]
    },
    {
      "title": "名词所有格（our）",
      "definition": "our是we的所有格形式，表示'我们的'",
      "structure": "our + 名词",
      "usage": "表示某物属于'我们'，后面接名词",
      "examples": [
        {
          "en": "Our cases are brown.",
          "zh": "我们的箱子是棕色的。"
        },
        {
          "en": "Are these our passports?",
          "zh": "这些是我们的护照吗？"
        }
      ]
    }
  ],
