  "grammar": [
    {
      "title": "一般过去时 (Past Simple Tense)",
      "definition": "表示在过去某个特定时间发生的动作或存在的状态",
      "structure": "主语 + 动词过去式 + 其他",
      "usage": "用于描述过去的事情，常与表示过去的时间状语连用，如 yesterday, last week, a week ago 等",
      "examples": [
        {
          "en": "He was in the R.A.F.",
          "zh": "他曾在英国皇家空军服役。"
        },
        {
          "en": "He flew to Spain a week ago.",
          "zh": "他一周前飞往西班牙。"
        }
      ]
    },
    {
      "title": "一般将来时 (Future Simple Tense - will)",
      "definition": "表示将来会发生的动作或存在的状态",
      "structure": "主语 + will + 动词原形 + 其他",
      "usage": "用于描述未来的计划、预测或决定，will 表示临时决定或客观预测",
      "examples": [
        {
          "en": "He will fly to New York next month.",
          "zh": "他下个月将飞往纽约。"
        },
        {
          "en": "He'll return to London the week after next.",
          "zh": "再下周他将返回伦敦。"
        }
      ]
    },
    {
      "title": "现在完成时 (Present Perfect Tense)",
      "definition": "表示过去发生的动作对现在造成的影响，或表示从过去持续到现在的经验",
      "structure": "主语 + has/have + 过去分词 + 其他",
      "usage": "already 用于肯定句中，表示某事已经发生。注意：already 一般放在助动词和实义动词之间，或放在句末",
      "examples": [
        {
          "en": "He has already been to nearly every country in the world.",
          "zh": "他已经几乎去过世界上每个国家了。"
        }
      ]
    }
  ],
