  "grammar": [
    {
      "title": "What colour is/are...? 询问颜色",
      "definition": "用What colour引导的特殊疑问句，用于询问某物的颜色",
      "structure": "What colour + is/are + 主语?",
      "usage": "当主语是单数名词时用is，复数名词时用are，this/that/it等单数代词用is，these/those/they等复数代词用are",
      "examples": [
        {
          "en": "What colour is your new dress?",
          "zh": "你的新连衣裙是什么颜色的？"
        },
        {
          "en": "What colour is it?",
          "zh": "它是什么颜色的？"
        },
        {
          "en": "What colour are your shoes?",
          "zh": "你的鞋子是什么颜色的？"
        }
      ]
    },
    {
      "title": "颜色表达：It's + 颜色",
      "definition": "描述某物颜色的基本句型",
      "structure": "主语 + is + 颜色形容词。",
      "usage": "颜色形容词作表语，说明主语的特征。颜色词前不加a/an",
      "examples": [
        {
          "en": "It's green.",
          "zh": "它是绿色的。"
        },
        {
          "en": "My car is red.",
          "zh": "我的车是红色的。"
        },
        {
          "en": "The sky is blue.",
          "zh": "天空是蓝色的。"
        }
      ]
    },
    {
      "title": "相同颜色表达：the same colour / too",
      "definition": "表达两件事物颜色相同或在已有颜色上再加同样的颜色",
      "structure": "1. It's the same colour (as...). 2. 主语 + is + 颜色 + too.",
      "usage": "the same colour表示两者完全相同，too表示also/also相同的意思",
      "examples": [
        {
          "en": "It's the same colour. (as my dress)",
          "zh": "它和我的裙子是一样的颜色。"
        },
        {
          "en": "It's green too.",
          "zh": "它也是绿色的。"
        },
        {
          "en": "My hat is red too.",
          "zh": "我的帽子也是红色的。"
        }
      ]
    }
  ],
