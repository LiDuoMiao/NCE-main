  "grammar": [
    {
      "title": "Be动词的一般疑问句",
      "definition": "将be动词(am/is/are)移到句首构成的疑问句，用于询问情况是否属实",
      "structure": "Be动词 + 主语 + 表语?",
      "usage": "用于需要用Yes或No回答的询问",
      "examples": [
        {
          "en": "Are you a teacher?",
          "zh": "你是一名教师吗？"
        },
        {
          "en": "Is she French?",
          "zh": "她是法国人吗？"
        }
      ]
    },
    {
      "title": "Be动词的否定句",
      "definition": "在be动词后加not构成否定句",
      "structure": "主语 + be动词 + not + 表语",
      "usage": "用于否认某种情况",
      "examples": [
        {
          "en": "I am not a teacher.",
          "zh": "我不是一名教师。"
        },
        {
          "en": "She is not French.",
          "zh": "她不是法国人。"
        }
      ]
    },
    {
      "title": "What引导的特殊疑问句",
      "definition": "以What开头的疑问句，用于询问具体信息",
      "structure": "What + be动词 + 主语 + ?",
      "usage": "询问职业、国籍等具体信息",
      "examples": [
        {
          "en": "What's your job?",
          "zh": "你的工作是什么？"
        },
        {
          "en": "What nationality are you?",
          "zh": "你是哪国人？"
        }
      ]
    }
  ],
