  "grammar": [
    {
      "title": "must be 表示肯定推测",
      "definition": "must be 用于表示根据现有证据或情况得出的肯定推测，意思是一定、肯定。",
      "structure": "主语 + must be + 形容词/名词",
      "usage": "当说话人有把握确定某事时使用must be，表示非常肯定的推测。否定形式用can't be（不可能是）。",
      "examples": [
        {
          "en": "It must be Karen Marsh.",
          "zh": "那一定是凯伦·马什。"
        },
        {
          "en": "She must be at least forty.",
          "zh": "她一定至少四十岁了。"
        },
        {
          "en": "It can't be Conrad Reeves.",
          "zh": "那不可能是康拉德·里夫斯。"
        }
      ]
    },
    {
      "title": "反义疑问句（附加疑问句）",
      "definition": "反义疑问句由陈述句加简短疑问句组成，前否定后肯定或前肯定后否定。",
      "structure": "陈述句 + 否定/肯定附加问句？",
      "usage": "用于寻求确认或同意，语调不同表示的意义不同：升调表示询问，降调表示强调。",
      "examples": [
        {
          "en": "Doesn't Karen Marsh look old!",
          "zh": "凯伦·马什看起来不是很老吗！"
        },
        {
          "en": "She does, doesn't she!",
          "zh": "她确实很老，不是吗！"
        },
        {
          "en": "That was a long time ago, wasn't it?",
          "zh": "那是很久以前的事了，不是吗？"
        }
      ]
    },
    {
      "title": "过去时态（was, read）",
      "definition": "表示过去发生的动作或存在的状态",
      "structure": "主语 + was/were + ... / 主语 + 动词过去式",
      "usage": "描述过去的情况、动作或状态，与现在形成对比",
      "examples": [
        {
          "en": "She was a famous actress when I was still at school.",
          "zh": "当我还在上学时她就是著名演员了。"
        },
        {
          "en": "I read she's twenty-nine.",
          "zh": "我读到（到的信息）是她二十九岁。"
        }
      ]
    }
  ],
