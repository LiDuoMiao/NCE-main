  "grammar": [
    {
      "title": "特殊疑问句 - What 引导的询问工作",
      "definition": "用What询问某人的职业或工作",
      "structure": "What + are/is + 主语 + jobs?",
      "usage": "用于询问一个人或多人的职业",
      "examples": [
        {
          "en": "What are their jobs?",
          "zh": "他们的工作是什么？"
        },
        {
          "en": "What is her job?",
          "zh": "她的工作是什么？"
        },
        {
          "en": "What are your jobs?",
          "zh": "你们的工作是什么？"
        }
      ]
    },
    {
      "title": "特殊疑问句 - Who 引导的询问身份",
      "definition": "用Who询问某人是谁",
      "structure": "Who is this + (形容词) + (名词)?",
      "usage": "用于询问某人的身份或名字",
      "examples": [
        {
          "en": "Who is this young man?",
          "zh": "这个年轻人是谁？"
        },
        {
          "en": "Who is that woman?",
          "zh": "那个女人是谁？"
        }
      ]
    },
    {
      "title": "特殊疑问句 - How 引导的问候",
      "definition": "How do you do? 是正式场合的问候语",
      "structure": "How do you do?",
      "usage": "第一次见面时的正式问候，回答也是 How do you do?",
      "examples": [
        {
          "en": "How do you do?",
          "zh": "你好（幸会）。"
        },
        {
          "en": "How do you do? Nice to meet you.",
          "zh": "你好，幸会。很高兴认识你。"
        }
      ]
    }
  ],
