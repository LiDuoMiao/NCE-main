  "grammar": [
    {
      "title": "指示代词 these 和 those",
      "definition": "this/these指代离说话人较近的事物，that/those指代离说话人较远的事物",
      "structure": "These (these glasses) / Those (those glasses)",
      "usage": "用于区分和指代不同位置的复数事物，在对话中明确所指的是哪些东西",
      "examples": [
        {
          "en": "These glasses? No, not those. The ones on the shelf.",
          "zh": "这些玻璃杯吗？不，不是那些。是架子上的那些。"
        }
      ]
    },
    {
      "title": "代词 one/ones 的用法",
      "definition": "one用来替代上文出现的单数名词，ones用来替代复数名词，避免重复",
      "structure": "the + ones + 介词短语/定语从句",
      "usage": "当需要明确指出是哪些东西时，用the ones加上修饰语来限定",
      "examples": [
        {
          "en": "I want the ones on the shelf.",
          "zh": "我想要架子上的那些。"
        }
      ]
    },
    {
      "title": "Which 引导的特殊疑问句",
      "definition": "Which用于提问，在一定范围内选择，询问具体是哪一个或哪些",
      "structure": "Which + 名词 + ...?",
      "usage": "用于在多个事物中进行选择和确认时使用",
      "examples": [
        {
          "en": "Which glasses does the man want?",
          "zh": "这个男人想要哪个玻璃杯？"
        },
        {
          "en": "Which books are yours?",
          "zh": "哪些书是你的？"
        }
      ]
    }
  ],
