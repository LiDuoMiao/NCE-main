  "grammar": [
    {
      "title": "情态动词 can 的用法 (Can 的肯定句和否定句)",
      "definition": "can是情态动词，表示能力或许可。否定形式是 cannot 或 can't。",
      "structure": "主语 + can/can not (can't) + 动词原形",
      "usage": "表达能够做某事或不能做某事",
      "examples": [
        {
          "en": "I can type this letter.",
          "zh": "我能打这封信。"
        },
        {
          "en": "I can't read it.",
          "zh": "我看不懂。"
        },
        {
          "en": "Can she type this letter?",
          "zh": "她能打这封信吗？"
        }
      ]
    },
    {
      "title": "Can 引导的一般疑问句",
      "definition": "将 can 移到句首构成一般疑问句，用于询问是否能够做某事。",
      "structure": "Can + 主语 + 动词原形?",
      "usage": "询问某人是否有能力或许可做某事",
      "examples": [
        {
          "en": "Can you come here a minute?",
          "zh": "你能过来一下吗？"
        },
        {
          "en": "Can she type this letter for me?",
          "zh": "她能帮我打这封信吗？"
        },
        {
          "en": "Can you type this letter for the boss?",
          "zh": "你能帮老板打这封信吗？"
        }
      ]
    }
  ],
