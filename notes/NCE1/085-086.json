  "grammar": [
    {
      "title": "现在完成时 (Present Perfect Tense)",
      "definition": "现在完成时表示过去发生的动作或状态与现在有联系，或强调动作的结果。它由have/has + 过去分词构成。",
      "structure": "主语 + have/has + 过去分词",
      "usage": "用于描述过去发生并持续到现在的情况，或表示过去的动作对现在的影响。本课中Have you just been to...?使用just表示刚刚发生。",
      "examples": [
        {
          "en": "Have you just been to the cinema?",
          "zh": "你刚去过电影院吗？"
        },
        {
          "en": "Yes, I have.",
          "zh": "是的，我去过了。"
        },
        {
          "en": "I've already seen it.",
          "zh": "我已经看过了。"
        }
      ]
    },
    {
      "title": "现在完成时与一般过去时的区别",
      "definition": "现在完成时强调与现在的联系，不明确指出动作发生的时间；一般过去时明确指出过去的时间，适用于具体的时间状语。",
      "structure": "现在完成时: have/has + 过去分词；一般过去时: 主语 + 过去式",
      "usage": "当有时间状语明确指出过去时间时，用一般过去时；当不强调时间或与现在有关联时，用现在完成时。本课中I was there in April用一般过去时，因为有具体时间April。",
      "examples": [
        {
          "en": "Have you ever been to Paris? (不强调具体时间)",
          "zh": "你去过巴黎吗？"
        },
        {
          "en": "I was there in April. (有具体时间April)",
          "zh": "四月我在那里。"
        },
        {
          "en": "I saw it on television last year. (有具体时间last year)",
          "zh": "我去年在电视上看的。"
        }
      ]
    },
    {
      "title": "Have you ever...? 句型",
      "definition": "Have you ever...? 用来询问某人是否曾经有过某种经历。ever意为“在任何时候；曾经”。",
      "structure": "Have/Has + 主语 + ever + 过去分词?",
      "usage": "用于询问经历，答案可用Yes, I have. / No, I've never...等回答",
      "examples": [
        {
          "en": "Have you ever been to Paris?",
          "zh": "你去过巴黎吗？"
        },
        {
          "en": "Yes, I have.",
          "zh": "是的，我去过。"
        },
        {
          "en": "No, I've never been there.",
          "zh": "不，我从未去过。"
        }
      ]
    }
  ],
