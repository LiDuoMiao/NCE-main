  "grammar": [
    {
      "title": "现在进行时 (Present Continuous Tense)",
      "definition": "表示说话时正在进行的动作",
      "structure": "主语 + am/is/are + 动词-ing",
      "usage": "描述说话人此刻正在进行的动作",
      "examples": [
        {
          "en": "What are you doing?",
          "zh": "你正在做什么？"
        },
        {
          "en": "I'm making a bookcase.",
          "zh": "我正在做一个书架。"
        }
      ]
    },
    {
      "title": "be going to 表示将来",
      "definition": "表示已经计划或决定要做的将来动作",
      "structure": "主语 + am/is/are + going to + 动词原形",
      "usage": "表达明确的计划或意图",
      "examples": [
        {
          "en": "What are you going to do now?",
          "zh": "你打算现在做什么？"
        },
        {
          "en": "I'm going to paint it pink.",
          "zh": "我打算把它漆成粉色。"
        }
      ]
    },
    {
      "title": "特殊疑问句 (Special Questions)",
      "definition": "用疑问词提问，需要具体回答的问句",
      "structure": "疑问词 + am/is/are + 主语 + ...?",
      "usage": "用于询问具体信息，如动作、颜色等",
      "examples": [
        {
          "en": "What colour are you going to paint it?",
          "zh": "你打算把它漆成什么颜色？"
        }
      ]
    }
  ],
