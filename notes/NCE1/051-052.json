  "grammar": [
    {
      "title": "使用 It 表示天气",
      "definition": "在英语中，常用代词 'it' 来表示天气，而不使用具体的主语。",
      "structure": "It's + 形容词 (hot, cold, warm, pleasant...) / It + 动词 (rains, snows, shines...)",
      "usage": "当描述天气状况时，使用 'it' 作为主语，而不是具体的事物如 'the sky' 或 'the weather'。",
      "examples": [
        {
          "en": "It's very pleasant.",
          "zh": "天气很宜人。"
        },
        {
          "en": "It rains sometimes.",
          "zh": "有时下雨。"
        },
        {
          "en": "It snows sometimes.",
          "zh": "有时下雪。"
        }
      ]
    },
    {
      "title": "频率副词的使用",
      "definition": "频率副词表示动作或状态发生的频率程度。",
      "structure": "频率副词 + 形容词/动词 | 主语 + be + 频率副词 + 形容词",
      "usage": "always（总是）> often（经常）> sometimes（有时）> never（从不）。频率副词通常放在be动词之后、行为动词之前。",
      "examples": [
        {
          "en": "It's always hot in July.",
          "zh": "七月总是很热。"
        },
        {
          "en": "It's often windy in March.",
          "zh": "三月经常有风。"
        },
        {
          "en": "It's sometimes cold in October.",
          "zh": "十月有时很冷。"
        }
      ]
    },
    {
      "title": "一般现在时描述四季气候",
      "definition": "使用一般现在时描述某个季节通常的气候状况。",
      "structure": "It's (always/often/sometimes) + 形容词 + in + 月份/季节",
      "usage": "当描述某个季节或月份的一般气候特征时，使用一般现在时。",
      "examples": [
        {
          "en": "It's always warm in September.",
          "zh": "九月总是很暖和。"
        },
        {
          "en": "It's often cold in December.",
          "zh": "十二月经常很冷。"
        },
        {
          "en": "It's hot in summer.",
          "zh": "夏天很热。"
        }
      ]
    }
  ],
