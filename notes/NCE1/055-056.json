  "grammar": [
    {
      "title": "频率副词在一般现在时中的位置",
      "definition": "频率副词（always, usually, often, sometimes, never等）用于描述动作发生的频率，在一般现在时的句子中，通常放在行为动词之前，be动词和助动词之后",
      "structure": "主语 + be动词/助动词 + 频率副词 + 行为动词",
      "usage": "用于描述习惯性动作或日常活动",
      "examples": [
        {
          "en": "She always eats her lunch at noon.",
          "zh": "她总是在中午吃午饭。"
        },
        {
          "en": "He usually reads his newspaper.",
          "zh": "他通常看报纸。"
        },
        {
          "en": "Sometimes he watches television.",
          "zh": "有时他看电视。"
        }
      ]
    },
    {
      "title": "时间介词的用法",
      "definition": "in, at, on都是表示时间概念的介词，但使用规则不同：in用于较长的时间段（上午、下午、晚上、月份、年份、季节），at用于具体的时刻或短的时间段（中午、夜间），on用于具体日期或星期",
      "structure": "in + 较长时段 / at + 特定时刻 / on + 具体日期",
      "usage": "正确使用时间介词是英语表达的基础",
      "examples": [
        {
          "en": "In the morning, Mr. Sawyer goes to work.",
          "zh": "早上，索耶先生去上班。"
        },
        {
          "en": "She eats lunch at noon.",
          "zh": "她在中午吃午饭。"
        },
        {
          "en": "In the afternoon, she sees her friends.",
          "zh": "下午，她去看朋友。"
        },
        {
          "en": "At night, the children do homework.",
          "zh": "晚上，孩子们做作业。"
        }
      ]
    },
    {
      "title": "一般现在时描述日常活动",
      "definition": "一般现在时用于描述经常发生的动作、习惯或客观事实。当主语是第三人称单数时，动词需要加-s或-es",
      "structure": "主语 + 动词原形/动词第三人称单数 + 其他",
      "usage": "描述家庭成员的日常作息规律",
      "examples": [
        {
          "en": "Mr. Sawyer goes to work.",
          "zh": "索耶先生去上班。"
        },
        {
          "en": "The children go to school.",
          "zh": "孩子们去上学。"
        },
        {
          "en": "Mrs. Sawyer stays at home.",
          "zh": "索耶太太待在家里。"
        }
      ]
    }
  ],
