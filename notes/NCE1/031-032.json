  "grammar": [
    {
      "title": "现在进行时 (Present Continuous Tense)",
      "definition": "表示正在进行的动作或发生的事，由be动词(am/is/are) + 动词-ing形式构成",
      "structure": "主语 + am/is/are + 动词-ing + 其他",
      "usage": "用于描述说话时正在发生的动作",
      "examples": [
        {
          "en": "She's sitting under the tree.",
          "zh": "她正坐在树下。"
        },
        {
          "en": "He's climbing the tree.",
          "zh": "他正在爬树。"
        },
        {
          "en": "It's running across the grass.",
          "zh": "它正在穿过草地跑。"
        }
      ]
    },
    {
      "title": "现在进行时的Yes/No疑问句",
      "definition": "将be动词提到句首构成一般疑问句，语调用升调",
      "structure": "Is/Are + 主语 + 动词-ing + 其他?",
      "usage": "用于询问某人是否正在做某事",
      "examples": [
        {
          "en": "Is Tim in the garden, too?",
          "zh": "Tim也在花园里吗？"
        },
        {
          "en": "Is the cat climbing the tree?",
          "zh": "那只猫正在爬树吗？"
        },
        {
          "en": "What's she doing?",
          "zh": "她正在做什么？"
        }
      ]
    },
    {
      "title": "Where引导的特殊疑问句",
      "definition": "用where提问地点，句式为Where + be动词 + 主语?",
      "structure": "Where + is/are + 主语?",
      "usage": "用于询问某人或某物在哪里",
      "examples": [
        {
          "en": "Where's Sally, Jack?",
          "zh": "Sally在哪里，Jack？"
        },
        {
          "en": "Where are the children?",
          "zh": "孩子们在哪里？"
        }
      ]
    }
  ],
