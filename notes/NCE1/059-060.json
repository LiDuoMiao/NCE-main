  "grammar": [
    {
      "title": "一般疑问句 (Yes/No Question) - 使用 Do/Does",
      "definition": "用Do或Does引导的疑问句，用来询问某人是否做某事或某物是否存在",
      "structure": "Do/Does + 主语 + 动词原形 + ...?",
      "usage": "当主语是第一人称(I, we)、第二人称(you)或复数主语时用Do；当主语是第三人称单数(he, she, it)时用Does",
      "examples": [
        {
          "en": "Do you have any writing paper?",
          "zh": "你有信纸吗？"
        },
        {
          "en": "Do you want a pad?",
          "zh": "你想要一个便笺本吗？"
        },
        {
          "en": "Does she have any brothers?",
          "zh": "她有兄弟吗？"
        }
      ]
    },
    {
      "title": "some和any的用法",
      "definition": "some和any都表示“一些”，some用于肯定句，any用于否定句和疑问句",
      "structure": "some + 可数名词复数/不可数名词; any + 可数名词复数/不可数名词",
      "usage": "在否定句和疑问句中用any，在肯定句中用some（表示请求或建议时也可用some）",
      "examples": [
        {
          "en": "I want some envelopes.",
          "zh": "我想要一些信封。"
        },
        {
          "en": "I don't have any small pads.",
          "zh": "我没有小号的便笺本。"
        },
        {
          "en": "Do you have any writing paper?",
          "zh": "你有信纸吗？"
        }
      ]
    },
    {
      "title": "选择疑问句 (Choice Question)",
      "definition": "用or连接两个选项，询问对方选择哪一个",
      "structure": "Do you want A or B?",
      "usage": "用于给出两个或多个选项让对方选择，回答时不用yes或no",
      "examples": [
        {
          "en": "Do you want the large size or the small size?",
          "zh": "你要大号的还是小号的？"
        },
        {
          "en": "Do you want tea or coffee?",
          "zh": "你想要茶还是咖啡？"
        }
      ]
    }
  ],
