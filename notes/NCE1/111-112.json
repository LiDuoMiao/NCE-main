  "grammar": [
    {
      "title": "形容词比较级和最高级",
      "definition": "形容词有两种比较形式：比较级用于两者之间的比较，最高级用于三者或以上的比较",
      "structure": "比较级：adj + -er / more + adj；最高级：the + adj + -est / the most + adj",
      "usage": "用于比较物品的价格、质量等",
      "examples": [
        {
          "en": "This model's less expensive than that one.",
          "zh": "这款比那款便宜。"
        },
        {
          "en": "It's the most expensive model in the shop.",
          "zh": "这是店里最贵的型号。"
        },
        {
          "en": "The other model's more expensive.",
          "zh": "另一款更贵。"
        }
      ]
    },
    {
      "title": "as...as 结构",
      "definition": "表示两者在某方面相同或相等",
      "structure": "as + adj + as",
      "usage": "用于否定或肯定比较",
      "examples": [
        {
          "en": "It's not as good as the expensive one.",
          "zh": "它没有贵的那款好。"
        },
        {
          "en": "He is as tall as his brother.",
          "zh": "他和他哥哥一样高。"
        }
      ]
    },
    {
      "title": "特殊疑问句 How much",
      "definition": "用于询问物品的价格",
      "structure": "How much + does/do + 主语 + cost?",
      "usage": "询问具体金额",
      "examples": [
        {
          "en": "How much does it cost?",
          "zh": "这个多少钱？"
        },
        {
          "en": "How much does this television cost?",
          "zh": "这台电视机多少钱？"
        }
      ]
    }
  ],
