  "grammar": [
    {
      "title": "介绍他人的句型 This is...",
      "definition": "用This is...句型来介绍他人给对方认识",
      "structure": "This is + 人名/称谓",
      "usage": "在正式或非正式场合介绍两人认识时使用",
      "examples": [
        {
          "en": "This is Miss Sophie Dupont.",
          "zh": "这是苏菲·杜邦小姐。"
        },
        {
          "en": "Sophie, this is Hans.",
          "zh": "苏菲，这是汉斯。"
        }
      ]
    },
    {
      "title": "一般疑问句：Be动词开头",
      "definition": "将Be动词(am/is/are)移到句首构成一般疑问句，用来询问国籍",
      "structure": "Is/Are + 主语 + 国籍?",
      "usage": "用于询问某人的国籍，答语用Yes或No",
      "examples": [
        {
          "en": "Is Chang-woo Chinese?",
          "zh": "昌宇是中国人吗？"
        },
        {
          "en": "Is she French?",
          "zh": "她是法国人吗？"
        }
      ]
    },
    {
      "title": "国籍形容词",
      "definition": "描述来自某个国家的人的形容词",
      "structure": "主语 + is/are + 国籍形容词",
      "usage": "用于描述他人的国籍，国籍形容词首字母通常小写",
      "examples": [
        {
          "en": "She is French.",
          "zh": "她是法国人。"
        },
        {
          "en": "He is German.",
          "zh": "他是德国人。"
        }
      ]
    },
    {
      "title": "国藉名词与形容词",
      "definition": "英语中国籍形容词和国籍名词形式不同",
      "structure": "形容词: French/German/Chinese  名词: a Frenchman/German/Chinese",
      "usage": "描述国籍时常用形容词；指某国公民时用名词",
      "examples": [
        {
          "en": "Sophie is French. She is a Frenchwoman.",
          "zh": "苏菲是法国人。她是一位法国女士。"
        }
      ]
    }
  ],
