  "grammar": [
    {
      "title": "Whose 引导的特殊疑问句",
      "definition": "Whose是疑问代词，用来询问某物属于谁",
      "structure": "Whose + 名词 + is/are + 主语/地点?",
      "usage": "当需要询问某物的所属时使用",
      "examples": [
        {
          "en": "Whose shirt is that?",
          "zh": "那件衬衫是谁的？"
        },
        {
          "en": "Whose book is this?",
          "zh": "这是谁的书？"
        }
      ]
    },
    {
      "title": "Is this/that + 所有格 + 名词? 句型",
      "definition": "用于询问某物是否属于某人",
      "structure": "Is this/that + 限定词 + 名词 + (名词所有格)?",
      "usage": "询问物品的归属时使用，回答用Yes或No",
      "examples": [
        {
          "en": "Is this your shirt?",
          "zh": "这是你的衬衫吗？"
        },
        {
          "en": "Is this shirt Tim's?",
          "zh": "这件衬衫是蒂姆的吗？"
        }
      ]
    },
    {
      "title": "名词所有格",
      "definition": "在名词后加's表示所属关系",
      "structure": "名词 + 's",
      "usage": "表示某人拥有某物，用于人名后",
      "examples": [
        {
          "en": "Tim's shirt is white.",
          "zh": "蒂姆的衬衫是白色的。"
        },
        {
          "en": "This is Dave's shirt.",
          "zh": "这是戴夫的衬衫。"
        }
      ]
    }
  ],
