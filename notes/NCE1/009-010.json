  "grammar": [
    {
      "title": "How are you? 询问身体状况句型",
      "definition": "How are you? 是英语中询问他人身体或状况的常用问候语，属于特殊疑问句",
      "structure": "How + am/is/are + 主语 + (today)?",
      "usage": "用于日常问候，可根据对象选择 am/is/are",
      "examples": [
        {
          "en": "How are you today?",
          "zh": "你今天好吗？"
        },
        {
          "en": "How is he?",
          "zh": "他好吗？"
        },
        {
          "en": "How are they?",
          "zh": "他们好吗？"
        }
      ]
    },
    {
      "title": "Be动词引导的一般疑问句",
      "definition": "将 Be 动词（am/is/are）提前到句首构成的疑问句，必须用 Yes 或 No 回答",
      "structure": "Am/Is/Are + 主语 + 形容词/副词?",
      "usage": "用于询问某人或某物的状态、状况",
      "examples": [
        {
          "en": "Are you well today?",
          "zh": "你今天身体好吗？"
        },
        {
          "en": "Is Emma fine?",
          "zh": "Emma 好吗？"
        }
      ]
    },
    {
      "title": "Too 的用法",
      "definition": "too 是副词，意为\"也\"，用于肯定句末，通常用逗号与前文隔开",
      "structure": "主语 + 动词 + 其他 + too.",
      "usage": "表示与前面提到的情况相同，用于肯定句和疑问句的肯定回答后",
      "examples": [
        {
          "en": "I'm well, and she's well too.",
          "zh": "我很好，她也很好。"
        },
        {
          "en": "Nice to see you too.",
          "zh": "也很高兴见到你。"
        }
      ]
    }
  ],
