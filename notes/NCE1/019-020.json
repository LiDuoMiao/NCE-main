  "grammar": [
    {
      "title": "there be句型（存在句）",
      "definition": "表示某地存在某人或某物的句型",
      "structure": "There is/are + 名词 + 地点",
      "usage": "用于描述某处有某人或某物存在，注意be动词的单复数与后面的名词一致",
      "examples": [
        {
          "en": "There's an ice cream man.",
          "zh": "那边有个冰淇淋小贩。"
        },
        {
          "en": "There are two ice creams.",
          "zh": "有两个冰淇淋。"
        }
      ]
    },
    {
      "title": "一般现在时（现在进行时概念）",
      "definition": "描述当前时刻正在发生的动作或存在的状态",
      "structure": "be (am/is/are) + 动词-ing",
      "usage": "用于描述说话时正在进行的动作",
      "examples": [
        {
          "en": "We're tired and thirsty.",
          "zh": "我们又累又渴。"
        }
      ]
    },
    {
      "title": "一般疑问句的简略回答",
      "definition": "对Yes/No问句的简略肯定或否定回答",
      "structure": "Yes/No + 主语 + be动词",
      "usage": "避免重复整个句子，用代词或简略形式回答",
      "examples": [
        {
          "en": "Are you all right now? Yes, we are.",
          "zh": "你现在好了吗？是的，我们好了。"
        },
        {
          "en": "No, we aren't.",
          "zh": "不，我们还没好。"
        }
      ]
    }
  ],
