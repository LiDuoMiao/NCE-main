  "grammar": [
    {
      "title": "There be句型（存在句）",
      "definition": "用于表示某处存在某人或某物，是英语中描述位置和存在的重要句型",
      "structure": "There is/are + (a/an/some) + 名词 + 介词短语",
      "usage": "当名词是单数或不可数名词时用there is；当名词是复数时用there are。some用于肯定句，any用于否定句和疑问句",
      "examples": [
        {
          "en": "There is a television in the room.",
          "zh": "房间里有一台电视机。"
        },
        {
          "en": "There are some armchairs in the room.",
          "zh": "房间里有几把扶手椅。"
        }
      ]
    },
    {
      "title": "some和any的用法",
      "definition": "some和any都表示“一些”，但用法有所不同",
      "structure": "some + 可数名词复数/不可数名词；any + 可数名词复数/不可数名词",
      "usage": "some用于肯定句，any用于否定句和疑问句。但在表示请求或希望得到肯定回答的疑问句中，也可用some",
      "examples": [
        {
          "en": "There are some magazines on the television.",
          "zh": "电视上有一些杂志。"
        },
        {
          "en": "Are there any books on the stereo?",
          "zh": "音响上有书吗？"
        }
      ]
    }
  ],
