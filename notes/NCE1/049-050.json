  "grammar": [
    {
      "title": "一般现在时的否定句 (Present Simple Negative)",
      "definition": "表示主语经常性或习惯性的否定行为",
      "structure": "主语 + do not (don't) / does not (doesn't) + 动词原形",
      "usage": "当主语是第三人称单数时用doesn't，其他人称用don't。doesn't后接动词原形。",
      "examples": [
        {
          "en": "I like lamb, but my husband doesn't.",
          "zh": "我喜欢羊肉，但我丈夫不喜欢。"
        },
        {
          "en": "I don't like chicken either.",
          "zh": "我也不喜欢鸡肉。"
        },
        {
          "en": "He doesn't want any vegetables.",
          "zh": "他不要蔬菜。"
        }
      ]
    },
    {
      "title": "简略否定句 (Short Negative Responses)",
      "definition": "在对话中避免重复已说过的动词，用doesn't/don't代替",
      "structure": "主语 + doesn't / don't",
      "usage": "当前文已提及动作或爱好，后文提及同一主语时，可用简略否定形式。",
      "examples": [
        {
          "en": "I like lamb, but my husband doesn't.",
          "zh": "我喜欢羊肉，但我丈夫不喜欢（不喜欢羊肉）。"
        },
        {
          "en": "My husband likes steak, but he doesn't like chicken.",
          "zh": "我丈夫喜欢牛排，但他不喜欢鸡肉。"
        }
      ]
    },
    {
      "title": "一般现在时的一般疑问句 (Present Simple Yes/No Questions)",
      "definition": "询问某人是否想要或喜欢某物的问句",
      "structure": "Do / Does + 主语 + 动词原形 + ...?",
      "usage": "询问是否想要某物，或询问某人的喜好时使用。Does用于第三人称单数主语。",
      "examples": [
        {
          "en": "Do you want beef or lamb?",
          "zh": "你想要牛肉还是羊肉？"
        },
        {
          "en": "Do you want a chicken?",
          "zh": "你想要鸡肉吗？"
        }
      ]
    }
  ],
