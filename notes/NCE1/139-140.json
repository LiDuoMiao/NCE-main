  "grammar": [
    {
      "title": "反意疑问句 (Tag Questions)",
      "definition": "反意疑问句是附在陈述句后面的简短问句，用来确认或征求对方的意见。由肯定陈述句+否定简短问句或否定陈述句+肯定简短问句组成。",
      "structure": "陈述句 + , + 助动词/be动词/情态动词 + not + 主语(缩写)? 或 陈述句 + , + 主语 + 助动词/be动词/情态动词?",
      "usage": "用于确认陈述内容是否正确，或征求对方的同意。回答时要根据事实，而非根据问句的形式。",
      "examples": [
        {
          "en": "You work for the Overseas Engineering Company, don't you?",
          "zh": "你在海外工程公司工作，不是吗？"
        },
        {
          "en": "You are John Smith, the engineer, aren't you?",
          "zh": "你是约翰·史密斯，工程师，不是吗？"
        },
        {
          "en": "That is John Smith, isn't it?",
          "zh": "那是约翰·史密斯，不是吗？"
        }
      ]
    },
    {
      "title": "电话英语 (Telephone English)",
      "definition": "打电话时使用的特定表达方式，与面对面交流有所不同。",
      "structure": "Is that you, + 名字? / Speaking. / This is + 名字 + speaking.",
      "usage": "接电话或打电话时确认对方身份，或自我介绍。",
      "examples": [
        {
          "en": "Is that you, John?",
          "zh": "是你吗，约翰？"
        },
        {
          "en": "Yes, speaking.",
          "zh": "是的，我就是。"
        },
        {
          "en": "This is Mary speaking.",
          "zh": "我是玛丽。"
        }
      ]
    },
    {
      "title": "一般将来时 (will + 动词原形)",
      "definition": "表示将要发生的动作或存在的状态。",
      "structure": "主语 + will + 动词原形",
      "usage": "表示说话时未发生但预计会发生的事情，或临时决定的事。",
      "examples": [
        {
          "en": "We'll be late for dinner this evening.",
          "zh": "今晚我们晚餐会迟到。"
        },
        {
          "en": "I don't know when I'll finish.",
          "zh": "我不知道什么时候能完成。"
        }
      ]
    }
  ],
