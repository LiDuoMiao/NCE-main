  "grammar": [
    {
      "title": "一般疑问句（Is this...?）",
      "definition": "用be动词（is）开头，询问某物是否为对方的物品",
      "structure": "Is + this + your + 名词?",
      "usage": "用于询问某物是否属于某人，回答用Yes it is.或No it isn't.",
      "examples": [
        {
          "en": "Is this your umbrella?",
          "zh": "这是你的雨伞吗？"
        },
        {
          "en": "Is this your coat?",
          "zh": "这是你的外套吗？"
        }
      ]
    },
    {
      "title": "缩写形式 isn't",
      "definition": "is not的缩写形式，用于否定句和否定回答",
      "structure": "主语 + isn't",
      "usage": "在口语和书面语中，isn't比is not更常用",
      "examples": [
        {
          "en": "No, it isn't my umbrella.",
          "zh": "不，这不是我的雨伞。"
        },
        {
          "en": "This isn't my ticket.",
          "zh": "这不是我的票。"
        }
      ]
    },
    {
      "title": "Here is / Here's 句型",
      "definition": "表示\"这是...\"或\"...在这里\"，here's是here is的缩写",
      "structure": "Here is/Here's + your + 名词",
      "usage": "用于递东西给别人或指出某物所在位置",
      "examples": [
        {
          "en": "Here's your umbrella and your coat.",
          "zh": "这是你的雨伞和外套。"
        },
        {
          "en": "Here is my ticket.",
          "zh": "这是我的票。"
        }
      ]
    }
  ],
