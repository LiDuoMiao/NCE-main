  "phrases": [
    {
      "phrase": "What's the matter with...?",
      "usage": "用于询问某人怎么了或出了什么问题",
      "examples": [
        {
          "en": "What's the matter with him?",
          "zh": "他怎么了？"
        },
        {
          "en": "What's the matter with you?",
          "zh": "你怎么了？"
        }
      ]
    },
    {
      "phrase": "stay in bed",
      "usage": "表示卧床休息，通常用于病人",
      "examples": [
        {
          "en": "He must stay in bed for a week.",
          "zh": "他必须卧床休息一周。"
