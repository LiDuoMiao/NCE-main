  "grammar": [
    {
      "title": "have (got) 表示疾病",
      "definition": "在英语中，表示身体患病常用 have (got) + 疾病名词，而不是用助动词 be 形式",
      "structure": "主语 + have/has (got) + 疾病名词",
      "usage": "have got 是 have 的口语化表达，两者意义相同，都可表示患病状态。have a cold 表示感冒，have a headache 表示头疼等。",
      "examples": [
        {
          "en": "He has a bad cold.",
          "zh": "他得了重感冒。"
        },
        {
          "en": "I have got a headache.",
          "zh": "我头疼。"
        },
        {
          "en": "She has a stomachache.",
          "zh": "她肚子疼。"
        }
      ]
    },
    {
      "title": "must 表示必要性和义务",
      "definition": "must 表示必须、一定，表示来自说话者的命令或强烈的建议",
      "structure": "主语 + must + 动词原形",
      "usage": "must 没有人称变化，第三人称单数也不加 s。must 表示主观上的必须，常用于表达说话者认为必要的事情。must not (mustn't) 表示禁止。",
      "examples": [
        {
          "en": "We must call the doctor.",
          "zh": "我们必须请医生。"
        },
        {
          "en": "He must stay in bed for a week.",
          "zh": "他必须卧床休息一周。"
        },
        {
          "en": "You must finish your homework.",
          "zh": "你必须完成作业。"
        }
      ]
    },
    {
      "title": "询问病情的常用句型",
      "definition": "英语中询问他人身体状况的几种常见表达方式",
      "structure": "What's the matter (with...)? / What's wrong (with...)? / How do you feel?",
      "usage": "What's the matter 和 What's wrong 用来询问出了什么问题或怎么了，常与 with 连用引出询问对象。feel ill 表示感觉不舒服，look ill 表示看起来有病态。",
      "examples": [
        {
          "en": "What's the matter with him?",
          "zh": "他怎么了？"
        },
        {
          "en": "What's wrong with you?",
          "zh": "你怎么了？"
        },
        {
          "en": "He feels ill and looks ill.",
          "zh": "他感觉不舒服，看起来也有病。"
        }
      ]
    }
  ],
