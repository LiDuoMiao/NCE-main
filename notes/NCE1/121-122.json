  "grammar": [
    {
      "title": "定语从句（Relative Clauses）- 关系代词who/which/that",
      "definition": "定语从句用于修饰名词或代词，由关系代词who（指人）、which（指物）或that引导",
      "structure": "名词 + who/which/that + 句子",
      "usage": "用于限制性定语从句中，修饰先行词，明确指出是哪个人或物",
      "examples": [
        {
          "en": "The man who bought these books came back.",
          "zh": "买这些书的那个人回来了。"
        },
        {
          "en": "The books which are on the counter are expensive.",
          "zh": "柜台上的那些书很贵。"
        },
        {
          "en": "The lady who is standing behind the counter served me.",
          "zh": "站在柜台后面的那位女士接待了我。"
        }
      ]
    },
    {
      "title": "过去进行时（Past Continuous Tense）",
      "definition": "过去进行时表示过去某一时刻正在进行的动作",
      "structure": "was/were + 动词-ing",
      "usage": "用于描述过去正在发生的事件，或与另一个过去动作进行对比",
      "examples": [
        {
          "en": "The man I served was wearing a hat.",
          "zh": "我接待的那个人当时戴着一顶帽子。"
        },
        {
          "en": "She was standing behind the counter when I came in.",
          "zh": "我进来时她正站在柜台后面。"
        }
      ]
    }
  ],
  "sentencePatterns": [
    {
      "pattern": "Who + 动词 + 主语?",
      "original": {
        "en": "Who served you, sir?",
