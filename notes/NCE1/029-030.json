  "grammar": [
    {
      "title": "Must 用于表达义务和指令",
      "definition": "must是情态动词，表示'必须'，用于表达权威人士给别人的命令或指示",
      "structure": "Must + 动词原形",
      "usage": "当老师、家长或上司给指示时使用must，强调必要性",
      "examples": [
        {
          "en": "What must I do, Mrs. Jones?",
          "zh": "我必须做什么，琼斯夫人？"
        }
      ]
    },
    {
      "title": "祈使句 (Imperative)",
      "definition": "用于表达命令、请求或建议的句子，通常省略主语you",
      "structure": "动词原形 + 其他成分",
      "usage": "用于给指令、提要求或提出建议，主语you通常省略",
      "examples": [
        {
          "en": "Open the window.",
          "zh": "打开窗户。"
        },
        {
          "en": "Shut the door, please.",
          "zh": "请关门。"
        },
        {
          "en": "Make the bed.",
          "zh": "整理床铺。"
        }
      ]
    }
  ],
