  "grammar": [
    {
      "title": "一般过去时的用法 (Simple Past Tense)",
      "definition": "表示过去发生的动作或存在的状态，常与明确的时间状语连用",
      "structure": "主语 + 动词过去式",
      "usage": "描述过去发生的具体事件，常见时间标志词有yesterday, last night, the day before yesterday等",
      "examples": [
        {
          "en": "He telephoned me four times yesterday.",
          "zh": "他昨天给我打了四次电话。"
        },
        {
          "en": "I arrived home at six o'clock yesterday evening.",
          "zh": "我昨天傍晚六点钟到家的。"
        },
        {
          "en": "He telephoned again.",
          "zh": "他又打电话了。"
        }
      ]
    },
    {
      "title": "一般过去时的否定句 (Negative Sentences in Past Tense)",
      "definition": "在肯定句的动词前加did not (didn't)，动词还原为原形",
      "structure": "主语 + did not (didn't) + 动词原形",
      "usage": "用于否定过去发生的动作",
      "examples": [
        {
          "en": "I didn't answer the phone.",
          "zh": "我没有接电话。"
        },
        {
          "en": "He didn't telephone again.",
          "zh": "他没有再打电话。"
        }
      ]
    },
    {
      "title": "一般过去时的一般疑问句 (Yes/No Questions in Past Tense)",
      "definition": "将did提到句首，动词还原为原形",
      "structure": "Did + 主语 + 动词原形?",
      "usage": "用Yes或No回答的疑问句，询问过去是否发生某事",
      "examples": [
        {
          "en": "Did he telephone again last night?",
          "zh": "他昨晚又打电话了吗？"
        },
        {
          "en": "Did you say to him?",
          "zh": "你对他说什么了？"
        },
        {
          "en": "Yes, he did. / No, he didn't.",
          "zh": "是的，他打了。/ 不，他没有。"
        }
      ]
    }
  ],
