  "grammar": [
    {
      "title": "Must的用法",
      "definition": "must表示必须、义务，表示主观认为必要的事情。否定形式mustn't表示禁止、不允许。",
      "structure": "主语 + must/mustn't + 动词原形",
      "usage": "must用于肯定句表示必须做某事，mustn't表示禁止做某事。用于医生嘱咐时表达医嘱。",
      "examples": [
        {
          "en": "You must stay in bed for another two days.",
          "zh": "你必须再卧床两天。"
        },
        {
          "en": "He mustn't go to school yet.",
          "zh": "他还不能去上学。"
        },
        {
          "en": "He mustn't eat rich food.",
          "zh": "他不可以吃油腻的食物。"
        }
      ]
    },
    {
      "title": "Must引导的一般疑问句",
      "definition": "must开头的一般疑问句用于询问是否必须做某事，回答用Yes, ... must.或No, ... needn't.",
      "structure": "Must + 主语 + 动词原形?",
      "usage": "用于询问某事是否必须做。must疑问句的回答：如果必须，用Yes, ... must；如果不必须，用No, ... needn't（注意不是mustn't）。",
      "examples": [
        {
          "en": "Must he stay in bed?",
          "zh": "他必须卧床吗？"
        },
        {
          "en": "Yes, he must.",
          "zh": "是的，他必须卧床。"
        },
        {
          "en": "Can I see him please?",
          "zh": "我可以看看他吗？"
        }
      ]
    },
    {
      "title": "Can表示允许或能力",
      "definition": "can可以表示能力（能够）或允许（可以）",
      "structure": "主语 + can + 动词原形",
      "usage": "在医患对话中，can表示允许病人做某事，如起床活动",
      "examples": [
        {
          "en": "He can get up for about two hours each day.",
          "zh": "他每天可以起床两小时左右。"
        },
        {
          "en": "Can I see him please, Mrs. Williams?",
          "zh": "威廉斯太太，我可以看看他吗？"
        }
      ]
    }
  ],
