  "grammar": [
    {
      "title": "现在完成时（Present Perfect Tense）",
      "definition": "现在完成时表示过去发生的动作对现在造成的影响或结果，或从过去持续到现在的动作",
      "structure": "主语 + have/has + 过去分词",
      "usage": "常与already、just、yet等副词连用，表示已经或刚刚完成的动作",
      "examples": [
        {
          "en": "I've already had lunch.",
          "zh": "我已经吃过午饭了。"
        },
        {
          "en": "I've just had a cup, thank you.",
          "zh": "我刚喝了一杯，谢谢。"
        },
        {
          "en": "I don't know. I've already had my holiday this year.",
          "zh": "我不知道。我今年已经休过假了。"
        }
      ]
    },
    {
      "title": "一般过去时与现在完成时的区别",
      "definition": "一般过去时强调动作发生在过去且与现在无关；现在完成时强调过去动作对现在的影响",
      "structure": "一般过去时：主语 + 动词过去式；现在完成时：主语 + have/has + 过去分词",
      "usage": "当询问具体过去事件时用过去时；当强调过去经验对现在的影响时用现在完成时",
      "examples": [
        {
          "en": "Where did you go?（询问具体过去事件）",
          "zh": "你去了哪里？"
        },
        {
          "en": "I've already had my holiday this year.（强调今年的假期经历）",
          "zh": "我今年已经休过假了。"
        }
      ]
    },
    {
      "title": "Be going to 表示将来计划",
      "definition": "be going to结构用来表示已经决定或计划好的将来动作",
      "structure": "主语 + am/is/are + going to + 动词原形",
      "usage": "表示说话时已经计划好的、打算做的事，或根据迹象预测即将发生的事",
      "examples": [
        {
          "en": "Tom and I are going to have a holiday.",
          "zh": "汤姆和我打算去度假。"
        },
        {
          "en": "We're going to leave tomorrow.",
          "zh": "我们明天要离开了。"
        }
      ]
    }
  ],
