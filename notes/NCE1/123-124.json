  "grammar": [
    {
      "title": "定语从句（Relative Clause）- 省略关系代词",
      "definition": "当定语从句的先行词在从句中作宾语时，关系代词可以省略",
      "structure": "名词 + (that/whom/who) + 主语 + 动词...",
      "usage": "在口语和非正式书面语中，当关系代词在从句中作宾语时，常可省略。先行词指人时可用who/that/whom，指物时可用which/that",
      "examples": [
        {
          "en": "That's the man (who/whom/that) I told you about.",
          "zh": "这就是我跟你说过的那个男人。"
        },
        {
          "en": "They're people (who/that) I met during the trip.",
          "zh": "他们是我旅途中遇到的人。"
        },
        {
          "en": "That's the ship (which/that) we travelled on.",
          "zh": "这就是我们乘坐的轮船。"
        }
      ]
    },
    {
      "title": "What引导的感叹句",
      "definition": "What引导的感叹句用于表达强烈的情感",
      "structure": "What a/an + 形容词 + 可数名词单数 (+ 主语 + 动词)！",
      "usage": "what后面接名词，用于感叹名词的性质或特征",
      "examples": [
        {
          "en": "What a beautiful ship!",
          "zh": "多漂亮的轮船啊！"
        },
        {
          "en": "What a lovely day it is!",
          "zh": "多美好的一天啊！"
        },
        {
          "en": "What an interesting book this is!",
          "zh": "这是一本多有趣的书啊！"
        }
      ]
    },
    {
      "title": "一般过去时与时间状语",
      "definition": "表示在过去某个特定时间发生的动作或存在的状态",
      "structure": "主语 + 动词过去式 + 时间状语",
      "usage": "常与一般过去时连用的时间状语：during the trip（在旅途中）, when I came home（当我回家时）等",
      "examples": [
        {
          "en": "I grew a beard during the trip.",
          "zh": "我在旅途中留了胡子。"
        },
        {
          "en": "I shaved it off when I came home.",
          "zh": "我回家时把它刮掉了。"
        },
        {
          "en": "I took this photograph during my trip to Australia.",
          "zh": "我在澳大利亚旅行时拍了这张照片。"
        }
      ]
    }
  ],
