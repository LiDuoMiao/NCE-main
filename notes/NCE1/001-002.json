  "phrases": [
    {
      "phrase": "Excuse me",
      "usage": "用于引起他人注意、请求让路、或在打扰别人之前",
      "examples": [
        {
          "en": "Excuse me, is this your handbag?",
          "zh": "打扰一下，这是你的手提包吗？"
        },
        {
          "en": "Excuse me, where is the post office?",
          "zh": "打扰一下，邮局在哪里？"
        }
      ]
    },
    {
      "phrase": "Thank you very much",
      "usage": "表示非常感谢，语气较强",
      "examples": [
        {
          "en": "Thank you very much for your help.",
          "zh": "非常感谢你的帮助。"
        },
        {
          "en": "Thank you very much indeed.",
          "zh": "真是非常感谢。"
        }
      ]
    },
    {
      "phrase": "Pardon?",
      "usage": "用于没听清楚时礼貌地请求重复",
      "examples": [
        {
          "en": "Pardon? I didn't hear you clearly.",
          "zh": "请再说一遍？我没听清楚。"
        }
      ]
    },
    {
      "phrase": "Yes?",
      "usage": "用于回应他人的招呼或询问，表示在听",
      "examples": [
        {
          "en": "Excuse me! Yes?",
          "zh": "打扰一下！什么事？"
        }
      ]
    },
    {
      "phrase": "It's mine",
      "usage": "表示某物属于自己",
      "examples": [
        {
          "en": "Is this your book? Yes, it's mine.",
          "zh": "这是你的书吗？是的，是我的。"
        }
      ]
    }
  ],
  "grammar": [
    {
      "title": "一般疑问句 (Yes/No Question)",
      "definition": "可以用yes或no回答的疑问句，通常需要用升调朗读",
      "structure": "Be动词(Am/Is/Are) + 主语 + ...?",
      "usage": "用于询问某物是否属于某人，或询问某事是否属实",
      "examples": [
        {
          "en": "Is this your handbag?",
          "zh": "这是你的手提包吗？"
        },
        {
          "en": "Is this your pen?",
          "zh": "这是你的钢笔吗？"
        },
        {
          "en": "Is this your book?",
          "zh": "这是你的书吗？"
        }
      ]
    },
    {
      "title": "指示代词 this/that 的用法",
      "definition": "this指代离说话人较近的事物，that指代较远的事物",
      "structure": "this/that + 名词",
      "usage": "this用于指代近处的人或事物，在询问物品归属时常用this",
      "examples": [
        {
          "en": "Is this your handbag?",
          "zh": "这是你的手提包吗？"
        },
        {
          "en": "Is that your car?",
          "zh": "那是你的车吗？"
        }
      ]
    },
    {
      "title": "肯定回答的简略形式",
      "definition": "在口语中，回答时常用简略形式",
      "structure": "Yes, it is. / No, it isn't.",
      "usage": "回答一般疑问句时，可以用简略形式，避免重复完整句子",
      "examples": [
        {
          "en": "Is this your handbag? Yes, it is.",
          "zh": "这是你的手提包吗？是的，它是。"
        },
        {
          "en": "Is this your bag? No, it isn't.",
          "zh": "这是你的包吗？不，它不是。"
        }
      ]
    }
  ],
