  "grammar": [
    {
      "title": "一般过去时 (Past Simple Tense)",
      "definition": "表示过去发生的动作或存在的状态",
      "structure": "主语 + 动词过去式 + ...",
      "usage": "用于描述过去发生的行为或事件，如车祸发生在过去",
      "examples": [
        {
          "en": "I brought it here three days ago.",
          "zh": "我是三天前把它带来的。"
        },
        {
          "en": "I drove it into a lamp-post.",
          "zh": "我把它撞到了路灯柱上。"
        },
        {
          "en": "Ah yes, I remember now.",
          "zh": "啊，是的，我现在想起来了。"
        }
      ]
    },
    {
      "title": "yet在现在完成时中的用法",
      "definition": "yet用于现在完成时的疑问句和否定句中，表示'还'或'已经'",
      "structure": "Have/Has + 主语 + 过去分词 + yet?（疑问句）/ Have/Has + 主语 + not + 过去分词 + yet（否定句）",
      "usage": "用于询问或陈述某事是否已完成，常与still连用表达未完成",
      "examples": [
        {
          "en": "Have your mechanics finished yet?",
          "zh": "你的机械师完成了吗？"
        },
        {
          "en": "No, they haven't finished yet.",
          "zh": "不，他们还没完成。"
        },
        {
          "en": "Is my car ready yet?",
          "zh": "我的车修好了吗？"
        }
      ]
    },
    {
      "title": "一般过去时与现在完成时的对比",
      "definition": "一般过去时强调过去的具体时间或已完成的动作；现在完成时强调过去动作对现在的影响",
      "structure": "一般过去时：主语 + 动词过去式 + 具体时间；现在完成时：主语 + have/has + 过去分词",
      "usage": "当询问是否完成时用现在完成时，描述过去的具体事件用一般过去时",
      "examples": [
        {
          "en": "When did you bring it to us? I brought it here three days ago.",
          "zh": "你什么时候带来的？我是三天前带来的。"
        },
        {
          "en": "Have your mechanics finished yet? No, they're still working on it.",
          "zh": "你的机械师完成了吗？不，他们还在修。"
        }
      ]
    }
  ],
