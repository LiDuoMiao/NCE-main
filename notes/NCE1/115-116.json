  "grammar": [
    {
      "title": "否定疑问句 (Negative Questions)",
      "definition": "由否定词not与助动词/系动词/情态动词构成的疑问句，用于表达惊讶、确认或期望肯定回答",
      "structure": "Isn't/Don't/Can't + 主语 + ...?",
      "usage": "表达惊讶或难以置信的语气，或期望对方确认",
      "examples": [
        {
          "en": "Isn't there anyone at home?",
          "zh": "难道没有人吗？"
        }
      ]
    },
    {
      "title": "some和any的用法 (Some and Any)",
      "definition": "some用于肯定句，any用于否定句和疑问句",
      "structure": "some + 可数名词复数/不可数名词；any + 可数名词复数/不可数名词",
      "usage": "表示一些/任意数量的某物",
      "examples": [
        {
          "en": "Can you see anything?",
          "zh": "你能看见什么东西吗？"
        },
        {
          "en": "Everything's very quiet.",
          "zh": "一切都很安静。"
        }
      ]
    },
    {
      "title": "Let's 引导的建议句型 (Let's for Suggestions)",
      "definition": "Let's = Let us，用于提出建议或邀请",
      "structure": "Let's + 动词原形",
      "usage": "建议一起做某事",
      "examples": [
        {
          "en": "Let's try the back door.",
          "zh": "我们试试后门吧。"
        },
        {
          "en": "Let's have a drink.",
          "zh": "我们喝一杯吧。"
        }
      ]
    }
  ],
