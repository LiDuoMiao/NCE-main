  "grammar": [
    {
      "title": "一般过去时特殊疑问句",
      "definition": "询问过去发生的事情的时间、原因、方式等信息的疑问句",
      "structure": "疑问词 + did + 主语 + 动词原形 + 其他？",
      "usage": "用于询问过去动作的具体信息，如时间、原因等",
      "examples": [
        {
          "en": "How long did the exam last?",
          "zh": "考试持续了多久？"
        },
        {
          "en": "What did you do yesterday?",
          "zh": "你昨天做了什么？"
        },
        {
          "en": "When did she leave?",
          "zh": "她什么时候离开的？"
        }
      ]
    },
    {
      "title": "too...to 与 enough...to 结构",
      "definition": "表达'太...而不能'和'足够...可以'的含义",
      "structure": "too + 形容词 + (for sb) + to do sth / 形容词 + enough + (for sb) + to do sth",
      "usage": "too...to表示否定含义，enough...to表示肯定含义",
      "examples": [
        {
          "en": "They were too difficult for me.",
          "zh": "它们对我来说太难了。"
        },
        {
          "en": "The paper wasn't easy enough for me.",
          "zh": "试卷对我来说不够简单。"
        },
        {
          "en": "The book is easy enough to read.",
          "zh": "这本书足够简单，可以阅读。"
        },
        {
          "en": "He is too young to go to school.",
          "zh": "他太小了，不能上学。"
        }
      ]
    },
    {
      "title": "情态动词 could 的用法",
      "definition": "could 表示过去的能力或可能性",
      "structure": "主语 + could + 动词原形",
      "usage": "表示过去能够做某事（能力）或能够做到某事（可能性）",
      "examples": [
        {
          "en": "I could answer sixteen of the questions.",
          "zh": "我能回答16道题。"
        },
        {
          "en": "I couldn't answer the rest.",
          "zh": "我答不出其余的题。"
        },
        {
          "en": "Could you speak English then?",
          "zh": "那时候你会说英语吗？"
        }
      ]
    }
  ],
  "sentencePatterns": [
    {
      "pattern": "How long did + 主语 + 动词原形 + (其他)?",
      "original": {
        "en": "How long did the exam last?",
        "zh": "考试持续了多久？"
      },
      "imitations": [
        {
          "en": "How long did the movie last?",
          "zh": "电影持续了多久？"
        },
        {
          "en": "How long did the trip last?",
          "zh": "旅行持续了多久？"
        }
      ]
    },
    {
      "pattern": "主语 + think + 主语 + passed/failed + in + 科目",
      "original": {
        "en": "I think I passed in English and Mathematics.",
        "zh": "我想我英语和数学通过了。"
      },
      "imitations": [
        {
          "en": "I think I passed in History.",
          "zh": "我想我历史通过了。"
        },
        {
          "en": "She thinks she failed in Physics.",
          "zh": "她认为她物理没及格。"
        }
      ]
    },
    {
      "pattern": "too + 形容词 + for + 人称代词/名词",
      "original": {
        "en": "They were too difficult for me.",
        "zh": "对我来说它们太难了。"
      },
      "imitations": [
        {
          "en": "This problem is too hard for students.",
          "zh": "这个问题对学生来说太难了。"
        },
        {
          "en": "The book is too boring for children.",
          "zh": "这本书对孩子来说太无聊了。"
        }
      ]
    },
    {
      "pattern": "形容词 + enough + (for + 人称代词/名词) + to do sth",
      "original": {
        "en": "The English paper wasn't easy enough for me.",
        "zh": "英语试卷对我来说不够简单。"
      },
      "imitations": [
        {
          "en": "The seat isn't comfortable enough for him.",
          "zh": "这个座位对他来说不够舒服。"
        },
        {
          "en": "The room is big enough for five people.",
          "zh": "这个房间足够大，可以容纳五个人。"
        }
      ]
    }
  ]
