  "grammar": [
    {
      "title": "had better 表示建议",
      "definition": "had better 表示劝告或建议，意为\"应该\"、\"最好\"，含有说话者认为不这样做会有不良后果的意味。",
      "structure": "主语 + had better + 动词原形",
      "usage": "用于对某人提出建议或劝告，语气比should稍强，暗示如果不这样做会产生不好的结果。否定形式为 had better not。",
      "examples": [
        {
          "en": "We had better go back to the station now.",
          "zh": "我们现在最好回车站。"
        },
        {
          "en": "You had better hurry.",
          "zh": "你最好快点。"
        },
        {
          "en": "We had better not be late.",
          "zh": "我们最好不要迟到。"
        }
      ]
    },
    {
      "title": "时间的询问与表达",
      "definition": "学习用不同方式询问和表达时间，特别是关于火车时刻的表达。",
      "structure": "What time + will + 主语 + 动词...? / It's + 时间",
      "usage": "用于询问具体时间或报告时间。英语中时间的表达方式有多种，如 eight fifteen (8:15)、nineteen minutes past eight (8:19)。",
      "examples": [
        {
          "en": "What time will the next train leave?",
          "zh": "下一班火车什么时候出发？"
        },
        {
          "en": "At nineteen minutes past eight.",
          "zh": "八点十九分。"
        },
        {
          "en": "It's only three minutes to eight.",
          "zh": "现在才八点差三分。"
        }
      ]
    },
    {
      "title": "'s 所有格表示时间",
      "definition": "在表示时间、距离、金钱等的名词后加 's 构成所有格，表示持续的时间或距离。",
      "structure": "数词 + 名词复数 + 's + time",
      "usage": "用于表示一段时间，如 five hours' time 表示\"五个小时后\"。这种用法在正式场合或书面语中常见。",
      "examples": [
        {
          "en": "In five hours' time!",
          "zh": "五个小时后！"
        },
        {
          "en": "three days' time",
          "zh": "三天后"
        },
        {
          "en": "two weeks' holiday",
          "zh": "两周的假期"
        }
      ]
    }
  ],
