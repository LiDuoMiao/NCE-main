  "grammar": [
    {
      "title": "Must have + 过去分词（表示对过去的肯定推测）",
      "definition": "must have done 表示对过去发生的事情的肯定推测，意思是'一定做过...'",
      "structure": "主语 + must have + 过去分词 + 其他",
      "usage": "用于根据证据或理由对过去的事情进行肯定推测",
      "examples": [
        {
          "en": "You must have been driving at seventy miles an hour.",
          "zh": "你一定是一直以每小时七十英里的速度在开车。"
        },
        {
          "en": "I must have been dreaming.",
          "zh": "我一定是在做梦。"
        }
      ]
    },
    {
      "title": "Can't have + 过去分词（表示对过去事情的否定推测）",
      "definition": "can't have done 表示对过去发生的事情的否定推测，意思是'不可能...'",
      "structure": "主语 + can't have + 过去分词 + 其他",
      "usage": "用于表示对过去事情的强烈否定推测",
      "examples": [
        {
          "en": "I can't have been going that fast.",
          "zh": "我不可能开那么快。"
        }
      ]
    },
    {
      "title": "Had better (not) + 动词原形（表示建议）",
      "definition": "had better表示'最好.../应该...'，带有轻微的警告或命令语气，not表示否定建议",
      "structure": "主语 + had better (not) + 动词原形",
      "usage": "用于提出建议或警告，语气比should更强",
      "examples": [
        {
          "en": "You'd better not do it again!",
          "zh": "你最好不要再这样做了！"
        },
        {
          "en": "You'd better take my advice.",
          "zh": "你最好听我的建议。"
        }
      ]
    }
  ],
  "sentencePatterns": [
