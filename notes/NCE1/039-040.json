  "grammar": [
    {
      "title": "Be going to 表示将来计划",
      "definition": "be going to + 动词原形表示对未来的计划、意图或预测",
      "structure": "主语 + am/is/are + going to + 动词原形",
      "usage": "用于表达已经决定或计划好的将来动作",
      "examples": [
        {
          "en": "I'm going to put it on this table.",
          "zh": "我打算把它放在这张桌子上。"
        },
        {
          "en": "What are you going to do with that vase?",
          "zh": "你打算如何处理那个花瓶？"
        }
      ]
    },
    {
      "title": "否定祈使句 Don't + 动词原形",
      "definition": "在动词原形前加Don't构成否定祈使句，用于表示不要做某事",
      "structure": "Don't + 动词原形 + 其他",
      "usage": "用于命令、警告或请求他人不要做某事",
      "examples": [
        {
          "en": "Don't do that.",
          "zh": "不要那样做。"
        },
        {
          "en": "Don't drop it!",
          "zh": "别把它掉了！"
        },
        {
          "en": "Don't put it there.",
          "zh": "别把它放在那里。"
        }
      ]
    },
    {
      "title": "Be + 形容词 祈使句",
      "definition": "使用Be动词加形容词构成的祈使句",
      "structure": "Be + 形容词 + 其他",
      "usage": "用于提醒或要求他人保持某种状态或小心",
      "examples": [
        {
          "en": "Be careful!",
          "zh": "小心！"
        },
        {
          "en": "Be quiet!",
          "zh": "安静！"
        }
      ]
    }
  ],
