  "grammar": [
    {
      "title": "There be句型（肯定句）",
      "definition": "表示某处存在某人或某物，be动词的形式取决于后面名词的单复数",
      "structure": "There is/are + 名词 + 地点",
      "usage": "用于描述某个地方有什么东西存在",
      "examples": [
        {
          "en": "There is a refrigerator in the kitchen.",
          "zh": "厨房里有一台冰箱。"
        },
        {
          "en": "There is a bottle on the table.",
          "zh": "桌子上有一个瓶子。"
        },
        {
          "en": "There is a cup on the table, too.",
          "zh": "桌子上也有一个杯子。"
        }
      ]
    },
    {
      "title": "方位介词的使用",
      "definition": "介词用来表示位置或方向，in表示在里面，on表示在上面，in the middle of表示在中间",
      "structure": "on the right / on the left / in the middle of the room",
      "usage": "用于描述物品的位置和方位",
      "examples": [
        {
          "en": "It is on the right.",
          "zh": "它在右边。"
        },
        {
          "en": "The table is in the middle of the room.",
          "zh": "桌子在房间中间。"
        }
      ]
    },
    {
      "title": "颜色形容词",
      "definition": "形容词用来描述事物的特征，颜色形容词直接放在名词前面",
      "structure": "The + 名词 + is + 颜色",
      "usage": "用于描述物品的颜色",
      "examples": [
        {
          "en": "The refrigerator is white.",
          "zh": "冰箱是白色的。"
        },
        {
          "en": "The cooker is blue.",
          "zh": "炉灶是蓝色的。"
        }
      ]
    }
  ],
