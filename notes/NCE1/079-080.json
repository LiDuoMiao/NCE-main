  "grammar": [
    {
      "title": "Have got / Has got 表示拥有",
      "definition": "在英式英语中，have got 相当于 have，用来表示拥有或具备某种状态。否定式在 have 后加 not，疑问式将 have/have got 提前。",
      "structure": "主语 + have/has + got + 名词\n否定：主语 + haven't/hasn't + got + 名词\n疑问：Have/Has + 主语 + got + 名词？",
      "usage": "用于描述某人拥有某物或在某处有某物。has got 用于第三人称单数（he/she/it）。",
      "examples": [
        {
          "en": "We haven't got much tea or coffee.",
          "zh": "我们的茶叶和咖啡不多了。"
        },
        {
          "en": "We haven't got any meat at all.",
          "zh": "我们一点肉都没有了。"
        },
        {
          "en": "Have we got any beer and wine?",
          "zh": "我们有啤酒和葡萄酒吗？"
        }
      ]
    },
    {
      "title": "Some 和 Any 的用法",
      "definition": "some 和 any 都表示“一些”，some 用于肯定句，any 用于否定句和疑问句。",
      "structure": "some + 可数名词复数/不可数名词\nany + 可数名词复数/不可数名词",
      "usage": "some 通常用于肯定句，any 用于否定句和疑问句。但在表示请求或希望得到肯定回答的疑问句中，也可用 some。",
      "examples": [
        {
          "en": "We need some meat.",
          "zh": "我们需要一些肉。"
        },
        {
          "en": "We haven't got any sugar or jam.",
          "zh": "我们没有糖和果酱了。"
        }
      ]
    },
    {
      "title": "Much 和 Many 的用法",
      "definition": "much 用于修饰不可数名词，表示“许多”；many 用于修饰可数名词复数，表示“许多”。",
      "structure": "much + 不可数名词\nmany + 可数名词复数",
      "usage": "much 和 many 通常用于否定句和疑问句，在肯定句中更常用 a lot of。",
      "examples": [
        {
          "en": "We haven't got much tea or coffee.",
          "zh": "我们的茶叶和咖啡不多了。"
        },
        {
          "en": "We haven't got many tomatoes.",
          "zh": "我们的西红柿不多了。"
        }
      ]
    }
  ],
