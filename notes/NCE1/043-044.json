  "grammar": [
    {
      "title": "Can表示能力 (Can for Ability)",
      "definition": "can用于表达某人做某事的能力或可能性",
      "structure": "Can + 主语 + 动词原形?",
      "usage": "用于询问或陈述某人是否会做某事，否定形式为cannot或can't",
      "examples": [
        {
          "en": "Can you make the tea, Sam?",
          "zh": "你会泡茶吗，萨姆？"
        },
        {
          "en": "Yes, of course I can.",
          "zh": "当然会。"
        },
        {
          "en": "I can see the teapot, but I can't see the tea.",
          "zh": "我能看见茶壶，但看不见茶叶。"
        }
      ]
    },
    {
      "title": "There is/There are 表示存在",
      "definition": "用there is/there are来表示某处存在某物",
      "structure": "There is + 单数名词/不可数名词 + 地点; There are + 复数名词 + 地点",
      "usage": "用于描述某处有什么东西，some用于肯定句，any用于疑问句和否定句",
      "examples": [
        {
          "en": "Is there any water in this kettle?",
          "zh": "这个水壶里有水吗？"
        },
        {
          "en": "Yes, there is.",
          "zh": "有的。"
        },
        {
          "en": "There are some in the cupboard.",
          "zh": "橱柜里有一些。"
        }
      ]
    },
    {
      "title": "方位介词 (Prepositions of Place)",
      "definition": "表示位置关系的介词或介词短语",
      "structure": "behind/in front of/over there + 名词",
      "usage": "behind表示在后面，in front of表示在前面，over there表示在那边",
      "examples": [
        {
          "en": "It's over there, behind the teapot.",
          "zh": "在那边，茶壶后面。"
        },
        {
          "en": "It's in front of you!",
          "zh": "就在你前面！"
        }
      ]
    }
  ],
