  "grammar": [
    {
      "title": "情态动词 can 和 can't 的用法",
      "definition": "can表示能力或可能性，can't表示不能或不允许",
      "structure": "主语 + can/can't + 动词原形",
      "usage": "用于询问或陈述能力、请求许可、表达可能性。疑问句将can提前。",
      "examples": [
        {
          "en": "Can you come at 10 a.m. on Monday?",
          "zh": "您能星期一上午10点来吗？"
        },
        {
          "en": "Can't you wait till this afternoon?",
          "zh": "您不能等到下午吗？"
        },
        {
          "en": "The dentist can't see me now.",
          "zh": "牙医现在不能给我看。"
        }
      ]
    },
    {
      "title": "一般现在时与现在进行时",
      "definition": "一般现在时描述习惯性动作，现在进行时描述正在发生的动作",
      "structure": "主语 + 动词原形/动词+s / 主语 + am/is/are + 动词-ing",
      "usage": "一般现在时用于经常性的动作，现在进行时用于正在进行的动作",
      "examples": [
        {
          "en": "Do you have an appointment?",
          "zh": "您有预约吗？"
        },
        {
          "en": "The dentist is very busy at the moment.",
          "zh": "牙医此刻非常忙。"
        }
      ]
    },
    {
      "title": "一般过去时",
      "definition": "描述过去发生的动作或存在的状态",
      "structure": "主语 + 动词过去式",
      "usage": "用于叙述过去发生的事情",
      "examples": [
        {
          "en": "Good morning, Mr. Croft.",
          "zh": "早上好，Croft先生。"
        }
      ]
    }
  ],
